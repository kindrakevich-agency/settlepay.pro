# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — these are the secrets that should NEVER touch the repo.

# Generate with: php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=

# Production database — see Hetzner aaPanel → Databases for credentials
DATABASE_URL="mysql://settle:CHANGE_ME@127.0.0.1:3306/settle?serverVersion=10.11.6-MariaDB&charset=utf8mb4"

# Resend or Postmark transactional email
MAILER_DSN=resend+api://RESEND_API_KEY@default

# Alchemy or QuickNode endpoints (with API keys)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional — Sentry, PostHog, billing
SENTRY_DSN=
STRIPE_SECRET_KEY=
