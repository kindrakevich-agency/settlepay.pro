# ──────────────────────────────────────────────────────────────────────────
#  Settlepay — environment variables
# ──────────────────────────────────────────────────────────────────────────
#  HOW TO USE THIS FILE
#
#    1. Copy it to .env.local:        cp .env.example .env.local
#    2. Fill in every value below.
#    3. .env.local is GITIGNORED — never commit it. The file you see in
#       the public repo is THIS template only.
#
#  See docs/CRYPTO_BASICS.md for a beginner-friendly walk-through of every
#  external service mentioned below.
# ──────────────────────────────────────────────────────────────────────────


# ─── 1. Symfony app secret ───────────────────────────────────────────────
# Random 32-char hex string used to sign session cookies, CSRF tokens, etc.
# Keep it secret. Rotating it invalidates all existing sessions.
#
# Generate one with:   php -r 'echo bin2hex(random_bytes(16));'
APP_SECRET=


# ─── 2. Database (MariaDB) ────────────────────────────────────────────────
# Format:  mysql://USER:PASSWORD@HOST:PORT/DB_NAME?serverVersion=...&charset=utf8mb4
#
# LOCAL DEV:  the docker compose stack creates a 'settle' DB + user
#   automatically (compose.yaml). Use the line below verbatim.
#
# PRODUCTION: get the credentials from aaPanel → Databases. Settle was
#   installed via the aaPanel API so it's already in the panel UI.
DATABASE_URL="mysql://settle:settle@db:3306/settle?serverVersion=10.11.6-MariaDB&charset=utf8mb4"


# ─── 3. Redis ─────────────────────────────────────────────────────────────
# Used for caching, sessions, rate-limiting, and (later) Messenger queue.
#
# LOCAL DEV: docker compose runs Redis as the 'redis' service.
# PRODUCTION: localhost — Redis is shared with other apps on the server.
REDIS_URL=redis://redis:6379


# ─── 4. Outgoing email ────────────────────────────────────────────────────
# Settlepay sends invoice links, payment confirmations, password resets.
#
# DEV: leave as null://null (no emails sent locally — preview them in the
#   Symfony profiler at /_profiler).
# PRODUCTION: sign up for free at https://resend.com (100 emails/day on
#   the free tier — enough for MVP). Verify the settlepay.pro domain there
#   so emails go out as hello@settlepay.pro instead of resend.dev.
#
# Format for Resend:    resend+api://YOUR_KEY@default
# Format for Postmark:  postmark+api://YOUR_KEY@default
# Format for SMTP:      smtp://user:pass@host:port
MAILER_DSN=null://null

# What every outgoing email is From — change in one place.
# We deliberately don't use noreply@: Gmail/Outlook give it lower trust
# scores and it discourages legitimate customer replies.
# Recommended pattern: hello@yourdomain for general, security@ for password
# resets, billing@ for invoices — see README §14 for the full rationale.
MAILER_FROM_ADDRESS=hello@settlepay.pro
MAILER_FROM_NAME=Settlepay


# ─── 5. Blockchain RPC endpoints ──────────────────────────────────────────
# The chain listener talks to these to detect on-chain payments.
#
# Public RPC URLs (the defaults below) work but are heavily rate-limited
# and may go down. For production sign up for a free tier at:
#   - https://www.alchemy.com    (300M requests/month free)
#   - https://www.quicknode.com  (10M requests/month free)
# Either one gives you per-chain URLs that look like:
#   https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
#
# A single Alchemy account covers all four chains via separate URLs.
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Testnets — used when running listener with --testnet (free, public RPCs)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc


# ─── 6. Token price feed ──────────────────────────────────────────────────
# CoinGecko gives USD prices for any token. We snapshot the price at the
# moment a payment confirms so the dashboard can show "$X paid as Y USDC".
# The free public endpoint (no key) is sufficient for MVP volumes.
#
# If you hit the free rate limit (~30 calls/min) sign up for a Demo or
# Pro key at https://www.coingecko.com/en/api and replace the base URL.
COINGECKO_API_BASE=https://api.coingecko.com/api/v3


# ─── 7. Error tracking (optional) ─────────────────────────────────────────
# Sign up at https://sentry.io (free tier: 5,000 errors/month).
# Create a Symfony project → copy the DSN → paste here.
# Leave empty to disable.
SENTRY_DSN=


# ─── 8. Billing (Phase 2 — leave empty for MVP) ───────────────────────────
# Settlepay charges a small % fee per invoice + a Pro/Agency subscription.
# We bill freelancers monthly via Stripe (yes, fiat — for the freelancer's
# own subscription). Phase 1 is free + manual. Phase 2 plugs Stripe in.
#
# Get keys from https://dashboard.stripe.com/apikeys (Test mode first).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ─── 9. WalletConnect / Reown Project ID (frontend) ──────────────────────
# Lets clients pay from MOBILE wallets (Trust Wallet, Rainbow, Phantom,
# Coinbase Mobile, etc.) by scanning a QR code. Without this, only
# browser-extension wallets like MetaMask work.
#
# 30-second free signup:
#   1. Go to https://cloud.reown.com/sign-in (Reown is the new
#      WalletConnect company name — same service).
#   2. Sign in with email or GitHub.
#   3. Click "Create" → name it "Settlepay" → choose "WalletKit / AppKit".
#   4. Copy the Project ID (long hex string).
#   5. Paste below.
#
# This variable is read by VITE at frontend BUILD TIME (not at runtime),
# so it's bundled into public/build/assets/checkout-*.js. After changing
# it, run `pnpm build` again.
#
# It's safe to expose publicly — it just identifies your app to Reown's
# servers. It is NOT a secret.
VITE_WALLETCONNECT_PROJECT_ID=


# ─── 10. Google Identity Services sign-in (OPTIONAL) ─────────────────────
# Modern Google sign-in via the ID-token flow (no OAuth redirect).
#
# 1. Create an OAuth client at console.cloud.google.com:
#    APIs & Services → Credentials → Create Credentials → OAuth client ID
#    Application type: Web application
#    Authorized JavaScript origins: https://settlepay.pro (+ localhost:8080 for dev)
#    Authorized redirect URIs: leave empty (we use the ID-token flow)
# 2. Paste the Client ID below.
# 3. Flip GOOGLE_AUTH_ENABLED to 1.
#
# When GOOGLE_AUTH_ENABLED=0, /auth/google returns 404 and the front-end
# Google button is hidden. Use it as an emergency kill-switch if Google
# rotates keys or your project gets suspended.
GOOGLE_AUTH_ENABLED=0
GOOGLE_CLIENT_ID=
