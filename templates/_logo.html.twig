{#
    Settlepay logo v3 — chunky angular S + display-weight wordmark.

    The mark is a stark angular S — three thick horizontal bars + two
    vertical connectors, all sharp 90° corners, filled solid with a
    teal gradient. No strokes, no curves, no container box. The shape
    reads as S immediately at any size and stays sharp at favicon
    dimensions because it has zero curves to anti-alias.

    The wordmark is SVG `<text>` in Inter Display 800 (the heaviest cut
    of the family already on the site), tracking tightened to -0.025em
    so the letters lock together like a logotype. Renders crisply
    through the browser's font engine — no hand-drawn letterform
    proportions to second-guess.

    Color split is preserved via currentColor on each tspan, controlled
    by Tailwind text-* classes that flip in dark mode automatically.

    Usage in any template:
        from _logo.html.twig import logo
        logo()                          - default: md, with wordmark
        logo(size='lg')                 - bigger
        logo(size='sm', wordmark=false) - mark only
        logo(monogram_mode=true)        - wordmark + muted .pro suffix
#}

{% macro logo(size = 'md', wordmark = true, monogram_mode = false) %}
    {% set sizes = {
        sm: { h: 24 },
        md: { h: 32 },
        lg: { h: 44 },
        xl: { h: 64 }
    } %}
    {% set s = sizes[size] %}
    {% set uid = size ~ '-' ~ random(99999) %}
    {% set vbw = wordmark ? (monogram_mode ? 380 : 300) : 60 %}

    <svg height="{{ s.h }}" viewBox="0 0 {{ vbw }} 60" fill="none"
         xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Settlepay"
         class="select-none overflow-visible">

        <defs>
            {# Brand-teal gradient — light at top-left, deep at bottom-right.
               Diagonal gives the mark a sense of motion / depth. #}
            <linearGradient id="sp-grad-{{ uid }}" x1="6" y1="6" x2="50" y2="54" gradientUnits="userSpaceOnUse">
                <stop offset="0%"   stop-color="#5eead4"/>
                <stop offset="50%"  stop-color="#14b8a6"/>
                <stop offset="100%" stop-color="#0f766e"/>
            </linearGradient>
            {# Subtle inner highlight along the top edge — gives the solid
               shape just enough dimension to not look flat. #}
            <linearGradient id="sp-shine-{{ uid }}" x1="0" y1="0" x2="0" y2="20" gradientUnits="userSpaceOnUse">
                <stop offset="0%"   stop-color="#ffffff" stop-opacity="0.22"/>
                <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
            </linearGradient>
        </defs>

        {# ─── Mark: angular S ────────────────────────────────────────
             Single closed path. Coordinates trace the outline of an
             angular S clockwise. Three horizontal bars (top / middle /
             bottom) connect via two vertical jogs. #}
        <g>
            <path d="M 6 6
                     L 50 6
                     L 50 24
                     L 24 24
                     L 24 28
                     L 50 28
                     L 50 54
                     L 6 54
                     L 6 36
                     L 32 36
                     L 32 32
                     L 6 32 Z"
                  fill="url(#sp-grad-{{ uid }})"/>
            <path d="M 6 6
                     L 50 6
                     L 50 24
                     L 24 24
                     L 24 28
                     L 50 28
                     L 50 54
                     L 6 54
                     L 6 36
                     L 32 36
                     L 32 32
                     L 6 32 Z"
                  fill="url(#sp-shine-{{ uid }})"/>
        </g>

        {% if wordmark %}
            {# ─── Wordmark: Inter Display 800, tracking tight.
                  Letters render via the browser font engine — Inter is
                  already loaded for the rest of the site so no extra cost. #}
            <text x="72" y="44"
                  font-family="'Inter Display', Inter, ui-sans-serif, system-ui, sans-serif"
                  font-weight="800"
                  font-size="38"
                  letter-spacing="-0.025em"
                  text-rendering="optimizeLegibility"
                  style="font-feature-settings: 'ss01', 'cv11';">
                <tspan fill="currentColor" class="text-slate-900 dark:text-slate-50">settle</tspan><tspan fill="currentColor" class="text-brand-600 dark:text-brand-400">pay</tspan>
            </text>

            {% if monogram_mode %}
                <text x="262" y="44"
                      font-family="'Inter Display', Inter, ui-sans-serif, system-ui, sans-serif"
                      font-weight="500"
                      font-size="26"
                      letter-spacing="-0.01em"
                      fill="currentColor"
                      class="text-slate-400 dark:text-slate-500">.pro</text>
            {% endif %}
        {% endif %}
    </svg>
{% endmacro %}
