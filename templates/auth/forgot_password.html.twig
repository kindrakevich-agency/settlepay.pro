{% extends 'auth/_layout.html.twig' %}
{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'auth.forgot.title'|trans }} · Settlepay{% endblock %}

{% block auth_content %}
    {% if form.sent %}
        <div class="text-center">
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </div>
            <h1 class="mt-4 font-display text-2xl font-semibold tracking-tight">{{ 'auth.forgot.sent_title'|trans }}</h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.forgot.sent_sub'|trans }}</p>
        </div>
    {% else %}
        <header class="mb-7">
            <h1 class="font-display text-2xl font-semibold tracking-tight">{{ 'auth.forgot.title'|trans }}</h1>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.forgot.sub'|trans }}</p>
        </header>

        {% if form.errors|length > 0 %}
            <div class="mb-5 rounded-xl border border-danger-200 dark:border-danger-500/30 bg-danger-50 dark:bg-danger-500/10 p-3.5 text-sm text-danger-700 dark:text-danger-500">
                <ul class="space-y-1">{% for err in form.errors %}<li>· {{ err|trans }}</li>{% endfor %}</ul>
            </div>
        {% endif %}

        <form method="POST" novalidate class="space-y-4">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot-password') }}">
            <label class="block">
                <span class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'auth.email'|trans }}</span>
                <input type="email" name="email" value="{{ form.email }}" autocomplete="email" required
                       class="block w-full px-3.5 py-2.5 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition">
            </label>

            <button type="submit" class="w-full inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-3 text-sm font-semibold shadow-card hover:shadow-card-hover transition">
                {{ 'auth.forgot.submit'|trans }}
            </button>
        </form>
    {% endif %}
{% endblock %}

{% block auth_below %}
    <p class="mt-6 text-center text-sm text-slate-600 dark:text-slate-400">
        <a href="{{ path('auth_login', {_locale: locale}) }}" class="font-medium text-brand-600 dark:text-brand-400 hover:underline">{{ 'auth.forgot.back_login'|trans }}</a>
    </p>
{% endblock %}
