{% extends 'base.html.twig' %}
{% from '_logo.html.twig' import logo %}

{% set locale = app.request.locale|default('en') %}

{% block body %}
<div class="min-h-dvh bg-slate-50 dark:bg-slate-950 grid place-items-center px-6 py-10">
    {# Top bar — logo + locale switcher only, no nav. #}
    <div class="absolute top-0 inset-x-0 px-6 py-4 flex items-center justify-between">
        <a href="{{ path('marketing_home', {_locale: locale}) }}" aria-label="settlepay">{{ logo(size='sm') }}</a>
        <div class="flex items-center rounded-lg border border-slate-200 dark:border-slate-800 p-0.5 text-xs font-medium bg-white/80 dark:bg-slate-900/80 backdrop-blur">
            {% for code in ['en', 'uk', 'es'] %}
                {% set active = locale == code %}
                <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({_locale: code})) }}"
                   class="rounded-md px-2 py-1 transition
                          {{ active ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100' }}">
                    {{ code|upper }}
                </a>
            {% endfor %}
        </div>
    </div>

    <main class="relative w-full max-w-md">
        <div class="absolute -inset-6 rounded-3xl blur-2xl opacity-50 pointer-events-none" aria-hidden="true"
             style="background-image: radial-gradient(at 20% 30%, rgba(45,212,191,0.30) 0px, transparent 50%), radial-gradient(at 80% 70%, rgba(13,148,136,0.25) 0px, transparent 50%);"></div>

        <div class="relative rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 lg:p-10 shadow-pop animate-fade-in">
            {% block auth_content %}{% endblock %}
        </div>

        {% block auth_below %}{% endblock %}
    </main>
</div>
{% endblock %}
