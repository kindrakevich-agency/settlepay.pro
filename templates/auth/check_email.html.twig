{% extends 'auth/_layout.html.twig' %}
{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'auth.check_email.title'|trans }} · Settlepay{% endblock %}

{% block auth_content %}
    <div class="text-center">
        <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="m3 7 9 6 9-6"/>
            </svg>
        </div>
        <h1 class="mt-4 font-display text-2xl font-semibold tracking-tight">{{ 'auth.check_email.title'|trans }}</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.check_email.sub'|trans }}</p>

        <div class="mt-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/60 p-4 text-left text-sm text-slate-600 dark:text-slate-400">
            <p class="font-medium text-slate-900 dark:text-slate-100 mb-1.5">{{ 'auth.check_email.tips_title'|trans }}</p>
            <ul class="space-y-1 list-disc list-inside">
                <li>{{ 'auth.check_email.tip_1'|trans }}</li>
                <li>{{ 'auth.check_email.tip_2'|trans }}</li>
                <li>{{ 'auth.check_email.tip_3'|trans }}</li>
            </ul>
        </div>
    </div>
{% endblock %}

{% block auth_below %}
    <p class="mt-6 text-center text-sm text-slate-600 dark:text-slate-400">
        <a href="{{ path('auth_login', {_locale: locale}) }}" class="font-medium text-brand-600 dark:text-brand-400 hover:underline">{{ 'auth.check_email.back_login'|trans }}</a>
    </p>
{% endblock %}
