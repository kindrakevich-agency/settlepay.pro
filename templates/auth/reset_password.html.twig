{% extends 'auth/_layout.html.twig' %}
{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'auth.reset.title'|trans }} · Settlepay{% endblock %}

{% block auth_content %}
    {% if expired %}
        <div class="text-center">
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-warning-50 dark:bg-warning-500/10 text-warning-600 dark:text-warning-500">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <h1 class="mt-4 font-display text-2xl font-semibold tracking-tight">{{ 'auth.reset.expired_title'|trans }}</h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.reset.expired_sub'|trans }}</p>
            <a href="{{ path('auth_forgot_password', {_locale: locale}) }}" class="mt-6 inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-semibold transition">
                {{ 'auth.reset.request_new'|trans }}
            </a>
        </div>
    {% elseif done|default(false) %}
        <div class="text-center">
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-success-50 dark:bg-success-500/10 text-success-600 dark:text-success-500">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 12 5 5 9-11"/></svg>
            </div>
            <h1 class="mt-4 font-display text-2xl font-semibold tracking-tight">{{ 'auth.reset.done_title'|trans }}</h1>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.reset.done_sub'|trans }}</p>
            <a href="{{ path('auth_login', {_locale: locale}) }}" class="mt-6 inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-semibold shadow-card transition">
                {{ 'common.sign_in'|trans }}
            </a>
        </div>
    {% else %}
        <header class="mb-7">
            <h1 class="font-display text-2xl font-semibold tracking-tight">{{ 'auth.reset.title'|trans }}</h1>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'auth.reset.sub'|trans }}</p>
        </header>

        {% if form.errors|length > 0 %}
            <div class="mb-5 rounded-xl border border-danger-200 dark:border-danger-500/30 bg-danger-50 dark:bg-danger-500/10 p-3.5 text-sm text-danger-700 dark:text-danger-500">
                <ul class="space-y-1">{% for err in form.errors %}<li>· {{ err|trans }}</li>{% endfor %}</ul>
            </div>
        {% endif %}

        <form method="POST" novalidate class="space-y-4">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset-password') }}">
            <label class="block">
                <span class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'auth.password'|trans }}</span>
                <input type="password" name="password" autocomplete="new-password" required minlength="12"
                       class="block w-full px-3.5 py-2.5 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition">
                <span class="mt-1.5 block text-xs text-slate-500">{{ 'auth.password_hint'|trans }}</span>
            </label>
            <label class="block">
                <span class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'auth.password_confirm'|trans }}</span>
                <input type="password" name="password_confirm" autocomplete="new-password" required minlength="12"
                       class="block w-full px-3.5 py-2.5 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition">
            </label>
            <button type="submit" class="w-full inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-3 text-sm font-semibold shadow-card hover:shadow-card-hover transition">
                {{ 'auth.reset.submit'|trans }}
            </button>
        </form>
    {% endif %}
{% endblock %}
