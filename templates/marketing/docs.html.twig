{% extends 'marketing/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'docs.title'|trans }} · Settlepay{% endblock %}

{% block marketing_content %}
<section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'docs.title'|trans }}</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-400">{{ 'docs.intro'|trans }}</p>

    <div class="mt-10 grid gap-4">
        <a href="https://github.com/kindrakevich-agency/settlepay.pro/blob/main/docs/CRYPTO_BASICS.md" target="_blank" rel="noopener"
           class="block rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 hover:border-slate-300 dark:hover:border-slate-700 transition">
            <h2 class="font-semibold tracking-tight">{{ 'docs.crypto_basics_title'|trans }} ↗</h2>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'docs.crypto_basics_sub'|trans }}</p>
        </a>
        <a href="https://github.com/kindrakevich-agency/settlepay.pro/blob/main/README.md" target="_blank" rel="noopener"
           class="block rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 hover:border-slate-300 dark:hover:border-slate-700 transition">
            <h2 class="font-semibold tracking-tight">{{ 'docs.tech_overview_title'|trans }} ↗</h2>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'docs.tech_overview_sub'|trans }}</p>
        </a>
        <div class="rounded-2xl border-2 border-dashed border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
            <h2 class="font-semibold tracking-tight text-slate-500 dark:text-slate-500">{{ 'docs.api_title'|trans }}</h2>
            <p class="mt-1.5 text-sm text-slate-500 dark:text-slate-500">{{ 'docs.api_sub'|trans }}</p>
        </div>
    </div>

    <p class="mt-10 text-sm text-slate-500 dark:text-slate-500">{{ 'docs.contact'|trans|raw }}</p>
</section>
{% endblock %}
