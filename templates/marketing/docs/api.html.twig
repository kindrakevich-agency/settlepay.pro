{% extends 'marketing/docs/_layout.html.twig' %}

{% block docs_title %}{{ 'docs.nav.api'|trans }}{% endblock %}

{% block docs_body %}
<h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'docs.api.title'|trans }}</h1>
<p class="mt-3 text-slate-600 dark:text-slate-400">{{ 'docs.api.subtitle'|trans }}</p>

<h2 class="mt-10">{{ 'docs.api.auth_title'|trans }}</h2>
<p>{{ 'docs.api.auth_body'|trans }}</p>
<pre><code class="language-bash">curl https://settlepay.pro/api/v1/me \
  -H "Authorization: Bearer sk_pro_…"</code></pre>

<h2 class="mt-10">{{ 'docs.api.envelope_title'|trans }}</h2>
<p>{{ 'docs.api.envelope_body'|trans }}</p>
<pre><code class="language-json">{ "data": { …resource… }, "meta": { …pagination… } }
{ "error": { "code": "invoice.not_found", "message": "Invoice not found." } }</code></pre>

<h2 class="mt-10">{{ 'docs.api.endpoints_title'|trans }}</h2>
<table class="not-prose w-full mt-3 text-sm border-collapse">
    <thead class="text-left text-xs uppercase tracking-wide text-slate-500 dark:text-slate-500 border-b border-slate-200 dark:border-slate-800">
        <tr><th class="py-2 pr-3">Method</th><th class="py-2 pr-3">Path</th><th class="py-2">Description</th></tr>
    </thead>
    <tbody class="divide-y divide-slate-200 dark:divide-slate-800">
        <tr><td class="py-2 pr-3 font-mono text-success-600">GET</td><td class="py-2 pr-3 font-mono">/api/v1/me</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_me_get'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-warning-600">PATCH</td><td class="py-2 pr-3 font-mono">/api/v1/me</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_me_patch'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-success-600">GET</td><td class="py-2 pr-3 font-mono">/api/v1/invoices</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_list'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-brand-600">POST</td><td class="py-2 pr-3 font-mono">/api/v1/invoices</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_create'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-success-600">GET</td><td class="py-2 pr-3 font-mono">/api/v1/invoices/{uuid}</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_get'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-warning-600">PATCH</td><td class="py-2 pr-3 font-mono">/api/v1/invoices/{uuid}</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_patch'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-danger-600">DELETE</td><td class="py-2 pr-3 font-mono">/api/v1/invoices/{uuid}</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_delete'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-brand-600">POST</td><td class="py-2 pr-3 font-mono">/api/v1/invoices/{uuid}/send</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_send'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-brand-600">POST</td><td class="py-2 pr-3 font-mono">/api/v1/invoices/{uuid}/void</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_invoices_void'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-success-600">GET</td><td class="py-2 pr-3 font-mono">/api/v1/payments</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_payments_list'|trans }}</td></tr>
        <tr><td class="py-2 pr-3 font-mono text-success-600">GET</td><td class="py-2 pr-3 font-mono">/api/v1/payments/{id}</td><td class="py-2 text-slate-600 dark:text-slate-400">{{ 'docs.api.ep_payments_get'|trans }}</td></tr>
    </tbody>
</table>

<h2 class="mt-10">{{ 'docs.api.example_title'|trans }}</h2>
<p>{{ 'docs.api.example_body'|trans }}</p>
<pre><code class="language-bash">curl -X POST https://settlepay.pro/api/v1/invoices \
  -H "Authorization: Bearer sk_pro_…" \
  -H "Content-Type: application/json" \
  -d '{
    "client_name": "Acme Corp",
    "client_email": "ap@acme.com",
    "amount_cents": 250000,
    "currency": "USD",
    "description": "Brand identity (10h)",
    "due_date": "2026-06-01"
  }'</code></pre>
{% endblock %}
