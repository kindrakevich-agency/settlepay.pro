{% extends 'marketing/docs/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block docs_title %}{{ 'docs.nav.overview'|trans }}{% endblock %}

{% block docs_body %}
<h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'docs.overview.title'|trans }}</h1>
<p class="mt-3 text-slate-600 dark:text-slate-400">{{ 'docs.overview.subtitle'|trans }}</p>

<div class="not-prose mt-8 grid sm:grid-cols-2 gap-4">
    <a href="{{ path('marketing_docs_api', {_locale: locale}) }}"
       class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5 hover:border-brand-300 dark:hover:border-brand-700 transition">
        <p class="font-semibold tracking-tight">{{ 'docs.overview.api_title'|trans }}</p>
        <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'docs.overview.api_sub'|trans }}</p>
    </a>
    <a href="{{ path('marketing_docs_webhooks', {_locale: locale}) }}"
       class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5 hover:border-brand-300 dark:hover:border-brand-700 transition">
        <p class="font-semibold tracking-tight">{{ 'docs.overview.webhooks_title'|trans }}</p>
        <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400">{{ 'docs.overview.webhooks_sub'|trans }}</p>
    </a>
</div>

<h2 class="mt-12 font-display text-xl font-semibold tracking-tight">{{ 'docs.overview.quickstart_title'|trans }}</h2>
<ol class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-400 list-decimal pl-5">
    <li>{{ 'docs.overview.step1'|trans }}</li>
    <li>{{ 'docs.overview.step2'|trans }}</li>
    <li>{{ 'docs.overview.step3'|trans }}</li>
    <li>{{ 'docs.overview.step4'|trans }}</li>
</ol>
{% endblock %}
