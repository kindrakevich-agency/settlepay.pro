<p>{{ 'docs.webhooks.verify_body'|trans }}</p>

<h3 class="mt-6">Node.js</h3>
<pre><code class="language-javascript">import crypto from 'node:crypto';
import express from 'express';

const SECRET = process.env.SETTLEPAY_WEBHOOK_SECRET;
const app = express();

// Settlepay sends JSON — keep the raw body so the signature still matches.
app.post('/webhooks/settlepay',
  express.raw({ type: 'application/json' }),
  (req, res) =&gt; {
    const ts        = req.header('X-Settlepay-Timestamp');
    const signature = req.header('X-Settlepay-Signature');
    const body      = req.body.toString('utf8');

    const expected = crypto
      .createHmac('sha256', SECRET)
      .update(`${ts}.${body}`)
      .digest('hex');

    if (!crypto.timingSafeEqual(Buffer.from(signature), Buffer.from(expected))) {
      return res.status(401).end();
    }

    const event = JSON.parse(body);
    // …route by event.event…
    res.status(200).end();
  });</code></pre>

<h3 class="mt-6">PHP</h3>
<pre><code class="language-php">&lt;?php
$secret    = $_ENV['SETTLEPAY_WEBHOOK_SECRET'];
$body      = file_get_contents('php://input');
$timestamp = $_SERVER['HTTP_X_SETTLEPAY_TIMESTAMP'] ?? '';
$signature = $_SERVER['HTTP_X_SETTLEPAY_SIGNATURE'] ?? '';

$expected = hash_hmac('sha256', $timestamp . '.' . $body, $secret);

if (!hash_equals($expected, $signature)) {
    http_response_code(401);
    exit;
}

$event = json_decode($body, true);
// …route by $event['event']…</code></pre>

<h3 class="mt-6">Python</h3>
<pre><code class="language-python">import hmac, hashlib, os
from flask import Flask, request, abort

SECRET = os.environ['SETTLEPAY_WEBHOOK_SECRET'].encode()
app = Flask(__name__)

@app.route('/webhooks/settlepay', methods=['POST'])
def settlepay():
    ts        = request.headers.get('X-Settlepay-Timestamp', '')
    signature = request.headers.get('X-Settlepay-Signature', '')
    body      = request.get_data(as_text=True)

    expected = hmac.new(SECRET, f'{ts}.{body}'.encode(), hashlib.sha256).hexdigest()
    if not hmac.compare_digest(expected, signature):
        abort(401)

    event = request.get_json()
    # …route by event['event']…
    return ('', 200)</code></pre>

