{% extends 'marketing/_layout.html.twig' %}

{% block marketing_content %}
<article class="mx-auto max-w-3xl px-6 py-16 lg:py-20">
    <header class="mb-10">
        <h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{% block legal_title %}{% endblock %}</h1>
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">{{ 'legal.last_updated'|trans({'%date%': last_updated}) }}</p>

        <div class="mt-5 rounded-xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-4 flex gap-3 text-sm">
            <span class="grid h-5 w-5 place-items-center rounded-full bg-warning-500 text-white shrink-0 mt-0.5 text-xs font-bold">!</span>
            <p class="text-warning-700/90 dark:text-warning-500/90 leading-relaxed">{{ 'legal.draft_warning'|trans|raw }}</p>
        </div>
    </header>

    <div class="prose prose-slate dark:prose-invert max-w-none
                prose-headings:font-display prose-headings:tracking-tight
                prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-3
                prose-h3:text-base prose-h3:mt-6 prose-h3:mb-2
                prose-p:text-slate-700 dark:prose-p:text-slate-300 prose-p:leading-relaxed
                prose-li:text-slate-700 dark:prose-li:text-slate-300
                prose-a:text-brand-600 dark:prose-a:text-brand-400 prose-a:no-underline hover:prose-a:underline
                prose-strong:text-slate-900 dark:prose-strong:text-slate-100">
        {% block legal_body %}{% endblock %}
    </div>
</article>
{% endblock %}
