{% extends 'marketing/_layout.html.twig' %}

{% block marketing_content %}
<article class="mx-auto max-w-3xl px-6 py-16 lg:py-20
                [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:mt-12 [&_h2]:mb-4
                [&_h2]:text-slate-900 [&_h2]:dark:text-slate-100
                [&_h3]:font-semibold [&_h3]:text-base [&_h3]:mt-8 [&_h3]:mb-2
                [&_h3]:text-slate-900 [&_h3]:dark:text-slate-100
                [&_p]:text-slate-700 [&_p]:dark:text-slate-300 [&_p]:leading-relaxed [&_p]:my-4
                [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:my-4 [&_ul]:space-y-2
                [&_li]:text-slate-700 [&_li]:dark:text-slate-300 [&_li]:leading-relaxed
                [&_a]:text-brand-600 [&_a]:dark:text-brand-400 [&_a]:no-underline hover:[&_a]:underline
                [&_strong]:text-slate-900 [&_strong]:dark:text-slate-100 [&_strong]:font-semibold">
    <header class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-800">
        <h1 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">{% block legal_title %}{% endblock %}</h1>
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">{{ 'legal.last_updated'|trans({'%date%': last_updated}) }}</p>
    </header>

    {% block legal_body %}{% endblock %}
</article>
{% endblock %}
