{#
    Shared marketing topbar — used by home.html.twig AND every page that
    extends marketing/_layout.html.twig. One source of truth so inner
    pages and the home page never drift apart again.

    Anchor links (#features, #dashboard, #checkout) are rendered as
    absolute URLs to /{locale}/ so they work cross-page: from home the
    browser does a hash-scroll, from inner pages it navigates home and
    then scrolls.

    Mobile menu uses the grid-rows [0fr → 1fr] CSS trick to animate height
    without a hard-coded max-height, so the panel sizes itself naturally
    even when translations make labels longer.
#}
{% from '_logo.html.twig' import logo %}
{% set locale = app.request.locale|default('en') %}
{% set route = app.request.attributes.get('_route') %}
{% set route_params = app.request.attributes.get('_route_params')|default({}) %}
{% set home_url = path('marketing_home', {_locale: locale}) %}

<header class="sticky top-0 z-40 border-b border-slate-200/70 dark:border-slate-800/70 bg-white/80 dark:bg-slate-950/80 backdrop-blur supports-[backdrop-filter]:bg-white/60"
        data-topbar>
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3.5">
        <a href="{{ home_url }}" aria-label="settlepay home" class="-mx-2 px-2 py-1 rounded-lg hover:bg-slate-100/60 dark:hover:bg-slate-800/40 transition">
            {{ logo(size='md') }}
        </a>

        {# ───── Desktop nav — lighter weight, bigger type per design ───── #}
        <nav class="hidden md:flex items-center gap-1 text-base font-normal text-slate-500 dark:text-slate-400">
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ home_url }}#features">{{ 'nav.product'|trans }}</a>
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ home_url }}#dashboard">{{ 'nav.dashboard'|trans }}</a>
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ home_url }}#checkout">{{ 'nav.payments'|trans }}</a>
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ path('marketing_pricing', {_locale: locale}) }}">{{ 'nav.pricing'|trans }}</a>
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ path('marketing_agency', {_locale: locale}) }}">{{ 'nav.agency'|trans }}</a>
            <a class="rounded-lg px-3 py-2 hover:text-slate-900 dark:hover:text-slate-100 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition" href="{{ path('marketing_docs', {_locale: locale}) }}">{{ 'nav.docs'|trans }}</a>
        </nav>

        {# ───── Desktop right-side cluster ───── #}
        <div class="flex items-center gap-2">
            <div class="hidden sm:flex items-center rounded-lg border border-slate-200 dark:border-slate-800 p-0.5 text-xs font-medium">
                {% for code in ['en', 'uk', 'es'] %}
                    {% set active = locale == code %}
                    {% set switch_url = route ? path(route, route_params|merge({_locale: code})) : path('marketing_home', {_locale: code}) %}
                    <a href="{{ switch_url }}"
                       class="rounded-md px-2 py-1 transition
                              {{ active ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100' }}">
                        {{ code|upper }}
                    </a>
                {% endfor %}
            </div>
            {% if app.user %}
                {# Avatar source: workspace business identity if set, else email local-part.
                   "DE", "VI", etc. = first 2 chars of whichever wins. #}
                {% set _ws = current_workspace() %}
                {% set _avatar = (_ws and _ws.businessName) ? _ws.businessName
                                 : (_ws and _ws.name and _ws.name != 'Workspace') ? _ws.name
                                 : (app.user.email|split('@')|first) %}
                <a href="{{ path('dashboard_home', {_locale: locale}) }}"
                   class="hidden sm:inline-flex items-center gap-2 rounded-lg bg-slate-900 dark:bg-white px-3.5 py-2 text-sm font-medium text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 transition shadow-sm">
                    <span class="grid h-5 w-5 place-items-center rounded-md bg-white/20 dark:bg-slate-900/15 text-[10px] font-semibold">
                        {{ _avatar|slice(0, 2)|upper }}
                    </span>
                    {{ 'common.open_dashboard'|trans }}
                </a>
            {% else %}
                <a href="{{ path('auth_login', {_locale: locale}) }}" class="hidden sm:inline-flex rounded-lg px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition">
                    {{ 'common.sign_in'|trans }}
                </a>
                <a href="{{ path('auth_register', {_locale: locale}) }}" class="hidden sm:inline-flex items-center gap-1.5 rounded-lg bg-slate-900 dark:bg-white px-3.5 py-2 text-sm font-medium text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 transition shadow-sm">
                    {{ 'common.sign_up'|trans }}
                </a>
            {% endif %}

            {# ───── Hamburger (mobile only) ───── #}
            <button type="button"
                    class="md:hidden inline-flex items-center justify-center rounded-lg p-2 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950"
                    aria-controls="mobile-menu"
                    aria-expanded="false"
                    aria-label="{{ 'nav.toggle_menu'|trans }}"
                    data-mobile-toggle>
                <svg class="h-5 w-5 transition-transform duration-200 [&[data-state=open]]:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-icon-menu>
                    <line x1="3"  y1="6"  x2="21" y2="6"/>
                    <line x1="3"  y1="12" x2="21" y2="12"/>
                    <line x1="3"  y1="18" x2="21" y2="18"/>
                </svg>
                <svg class="h-5 w-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-icon-close>
                    <line x1="6"  y1="6"  x2="18" y2="18"/>
                    <line x1="6"  y1="18" x2="18" y2="6"/>
                </svg>
            </button>
        </div>
    </div>

</header>

{# ───── Full-screen mobile menu ─────
   Lives outside the <header> so the fixed overlay covers the entire
   viewport (including the sticky topbar itself). The frosted-glass
   blur over the page is achieved with backdrop-blur-2xl + a
   semi-transparent surface — the underlying page content stays
   slightly visible but heavily blurred.
   Opening locks <body> scroll. Animation: 250 ms opacity + scale
   fade-in on the surface. #}
<div id="mobile-menu"
     class="group/menu md:hidden fixed inset-0 z-50 opacity-0 pointer-events-none transition-opacity duration-300 ease-out
            data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto"
     data-open="false"
     data-mobile-panel
     role="dialog"
     aria-modal="true"
     aria-label="{{ 'nav.toggle_menu'|trans }}">

    {# Frosted-glass surface — covers full viewport, blurs the page
       behind it. bg-white/75 keeps light theme readable; the dark:
       variants keep dark theme cohesive. Scale subtly easing into 100% on open. #}
    <div class="absolute inset-0 bg-white/75 dark:bg-slate-950/80 backdrop-blur-2xl
                transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]
                scale-[1.02] group-data-[open=true]/menu:scale-100"></div>

    {# Decorative brand glow behind the menu — same gradient palette as the hero. #}
    <div class="absolute inset-0 pointer-events-none opacity-60" aria-hidden="true"
         style="background-image:
            radial-gradient(at 18% 18%, rgba(45,212,191,0.18) 0px, transparent 50%),
            radial-gradient(at 82% 82%, rgba(13,148,136,0.14) 0px, transparent 50%);"></div>

    <div class="relative flex h-full flex-col">
        {# Top bar inside the overlay: logo + close X #}
        <div class="flex items-center justify-between px-6 py-3.5 border-b border-slate-200/50 dark:border-slate-800/50">
            <a href="{{ home_url }}" aria-label="settlepay home" class="-mx-2 px-2 py-1 rounded-lg hover:bg-slate-100/60 dark:hover:bg-slate-800/40 transition">
                {{ logo(size='md') }}
            </a>
            <button type="button"
                    class="inline-flex items-center justify-center rounded-lg p-2 text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-slate-950"
                    aria-label="{{ 'nav.close_menu'|trans }}"
                    data-mobile-close>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="6" y1="6" x2="18" y2="18"/>
                    <line x1="6" y1="18" x2="18" y2="6"/>
                </svg>
            </button>
        </div>

        {# Main nav — large tap targets, generous vertical rhythm #}
        <nav class="flex-1 overflow-y-auto px-6 py-8">
            <ul class="flex flex-col gap-1">
                <li>
                    <a href="{{ home_url }}#features" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.product'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
                <li>
                    <a href="{{ home_url }}#dashboard" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.dashboard'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
                <li>
                    <a href="{{ home_url }}#checkout" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.payments'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
                <li>
                    <a href="{{ path('marketing_pricing', {_locale: locale}) }}" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.pricing'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
                <li>
                    <a href="{{ path('marketing_agency', {_locale: locale}) }}" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.agency'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
                <li>
                    <a href="{{ path('marketing_docs', {_locale: locale}) }}" class="group flex items-center justify-between rounded-2xl px-4 py-4 font-display text-2xl font-semibold tracking-tight text-slate-900 dark:text-slate-100 hover:bg-white/60 dark:hover:bg-slate-900/60 transition">
                        {{ 'nav.docs'|trans }}
                        <svg class="h-5 w-5 text-slate-400 group-hover:text-brand-600 group-hover:translate-x-1 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </li>
            </ul>
        </nav>

        {# Bottom slab: locale switcher + auth CTAs #}
        <div class="border-t border-slate-200/50 dark:border-slate-800/50 px-6 py-6 space-y-4">
            <div class="flex items-center justify-between gap-3">
                <span class="text-xs font-medium uppercase tracking-wide text-slate-500 dark:text-slate-500">{{ 'nav.language'|trans }}</span>
                <div class="flex items-center rounded-xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 p-0.5 text-xs font-medium backdrop-blur">
                    {% for code in ['en', 'uk', 'es'] %}
                        {% set active = locale == code %}
                        {% set switch_url = route ? path(route, route_params|merge({_locale: code})) : path('marketing_home', {_locale: code}) %}
                        <a href="{{ switch_url }}"
                           class="rounded-lg px-3 py-1.5 transition
                                  {{ active ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900' : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100' }}">
                            {{ code|upper }}
                        </a>
                    {% endfor %}
                </div>
            </div>

            {% if app.user %}
                <a href="{{ path('dashboard_home', {_locale: locale}) }}"
                   class="flex items-center gap-3 rounded-xl bg-slate-900 dark:bg-white px-4 py-3.5 text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 transition shadow-card">
                    <span class="grid h-9 w-9 place-items-center rounded-lg bg-white/20 dark:bg-slate-900/15 text-sm font-semibold shrink-0">
                        {{ _avatar|slice(0, 2)|upper }}
                    </span>
                    <div class="flex-1 min-w-0 text-left">
                        <div class="text-sm font-semibold">{{ 'common.open_dashboard'|trans }}</div>
                        <div class="text-xs opacity-70 truncate">{{ app.user.email }}</div>
                    </div>
                    <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a href="{{ path('auth_logout', {_locale: locale}) }}"
                   class="mt-3 block text-center text-sm font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                    {{ 'common.log_out'|trans }}
                </a>
            {% else %}
                <div class="grid grid-cols-2 gap-3">
                    <a href="{{ path('auth_login', {_locale: locale}) }}" class="inline-flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur px-4 py-3 text-sm font-medium text-slate-900 dark:text-slate-100 hover:bg-white dark:hover:bg-slate-800 transition">
                        {{ 'common.sign_in'|trans }}
                    </a>
                    <a href="{{ path('auth_register', {_locale: locale}) }}" class="inline-flex items-center justify-center gap-1.5 rounded-xl bg-brand-600 hover:bg-brand-700 active:bg-brand-800 px-4 py-3 text-sm font-semibold text-white shadow-card transition">
                        {{ 'common.sign_up'|trans }}
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<script>
    (() => {
        const root   = document.querySelector('[data-topbar]');
        const panel  = document.querySelector('[data-mobile-panel]');
        if (!root || !panel) return;
        const btn    = root.querySelector('[data-mobile-toggle]');
        const iOpen  = root.querySelector('[data-icon-menu]');
        const iClose = root.querySelector('[data-icon-close]');
        const closeBtn = panel.querySelector('[data-mobile-close]');
        if (!btn) return;

        const setOpen = (open) => {
            panel.setAttribute('data-open', open ? 'true' : 'false');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
            iOpen?.classList.toggle('hidden',  open);
            iClose?.classList.toggle('hidden', !open);
            // Lock body scroll while the overlay is up.
            document.documentElement.style.overflow = open ? 'hidden' : '';
            document.body.style.overflow           = open ? 'hidden' : '';
        };

        btn.addEventListener('click', () => {
            setOpen(panel.getAttribute('data-open') !== 'true');
        });

        closeBtn?.addEventListener('click', () => setOpen(false));

        // Close on link click inside the overlay (so navigating to /pricing
        // doesn't leave the menu visible if the next page is same-origin).
        panel.addEventListener('click', (e) => {
            if (e.target.closest('a')) setOpen(false);
        });

        // Close on Escape.
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && panel.getAttribute('data-open') === 'true') {
                setOpen(false);
                btn.focus();
            }
        });

        // Close on resize past md (768px) so an open overlay doesn't linger
        // if the user rotates / resizes into desktop layout.
        const mq = window.matchMedia('(min-width: 768px)');
        mq.addEventListener('change', (e) => { if (e.matches) setOpen(false); });
    })();
</script>
