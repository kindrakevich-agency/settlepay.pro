{% extends 'base.html.twig' %}
{% from '_logo.html.twig' import logo %}

{% set locale = app.request.locale|default('en') %}

{% block body %}
{% include 'marketing/_topbar.html.twig' %}

{% block marketing_content %}{% endblock %}

{# ───── Footer ───── #}
<footer class="border-t border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
    <div class="mx-auto max-w-7xl px-6 py-10 flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            {{ logo(size='sm') }}
            <span class="text-xs text-slate-500 dark:text-slate-500">{{ 'footer.copyright'|trans }}</span>
        </div>
        <div class="flex items-center gap-6 text-xs text-slate-500 dark:text-slate-400">
            <a href="{{ path('marketing_pricing', {_locale: locale}) }}" class="hover:text-slate-900 dark:hover:text-slate-100">{{ 'footer.links.pricing'|trans }}</a>
            <a href="{{ path('marketing_privacy', {_locale: locale}) }}" class="hover:text-slate-900 dark:hover:text-slate-100">{{ 'footer.links.privacy'|trans }}</a>
            <a href="{{ path('marketing_terms', {_locale: locale}) }}"   class="hover:text-slate-900 dark:hover:text-slate-100">{{ 'footer.links.terms'|trans }}</a>
        </div>
    </div>
</footer>
{% endblock %}
