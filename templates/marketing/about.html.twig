{% extends 'marketing/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'about.seo.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'about.seo.description'|trans }}{% endblock %}

{% block marketing_content %}

{# ─── Hero ─── #}
<section class="relative overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true"
         style="background-image: radial-gradient(at 30% 20%, rgba(13,148,136,0.20) 0px, transparent 50%), radial-gradient(at 70% 60%, rgba(45,212,191,0.12) 0px, transparent 50%);"></div>
    <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-12 text-center">
        <p class="text-sm font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.hero.eyebrow'|trans }}</p>
        <h1 class="mt-3 font-display text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight">{{ 'about.hero.title'|trans }}</h1>
        <p class="mt-5 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">{{ 'about.hero.sub'|trans }}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            <a href="{{ path('auth_register', {_locale: locale}) }}"
               class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 text-sm font-semibold shadow-card transition">
                {{ 'about.hero.cta_primary'|trans }}
            </a>
            <a href="#how" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur px-5 py-3 text-sm font-medium hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                {{ 'about.hero.cta_secondary'|trans }}
            </a>
        </div>
    </div>
</section>

{# ─── The problem ─── #}
<section class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.problem.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.problem.title'|trans }}</h2>
            <p class="mt-4 text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{{ 'about.problem.sub'|trans }}</p>
        </div>
        <div class="mt-12 grid sm:grid-cols-2 gap-5">
            {% for n in 1..4 %}
                <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <h3 class="font-semibold tracking-tight text-lg">{{ ('about.problem.p' ~ n ~ '_title')|trans }}</h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('about.problem.p' ~ n ~ '_body')|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Our solution ─── #}
<section class="relative">
    <div class="mx-auto max-w-4xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.solution.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.solution.title'|trans }}</h2>
            <p class="mt-5 text-base text-slate-600 dark:text-slate-400 leading-relaxed">{{ 'about.solution.body'|trans }}</p>
        </div>
        <div class="mt-10 grid sm:grid-cols-2 gap-4">
            {% for n in 1..4 %}
                <div class="flex gap-3 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                    <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-success-50 dark:bg-success-500/15 text-success-600">
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 13l4 4L19 7"/></svg>
                    </span>
                    <p class="text-sm text-slate-700 dark:text-slate-300 leading-relaxed">{{ ('about.solution.bullet' ~ n)|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── How it works ─── #}
<section id="how" class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.how.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.how.title'|trans }}</h2>
            <p class="mt-4 text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{{ 'about.how.sub'|trans }}</p>
        </div>
        <ol class="mt-12 space-y-4">
            {% for n in 1..6 %}
                <li class="flex gap-5 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <span class="grid h-12 w-12 shrink-0 place-items-center rounded-2xl bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400 font-display text-xl font-semibold">{{ n }}</span>
                    <div class="flex-1">
                        <h3 class="font-semibold tracking-tight text-lg">{{ ('about.how.step' ~ n ~ '_title')|trans }}</h3>
                        <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('about.how.step' ~ n ~ '_body')|trans }}</p>
                    </div>
                </li>
            {% endfor %}
        </ol>
    </div>
</section>

{# ─── Why crypto-native (not Stripe) ─── #}
<section class="relative">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.why.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.why.title'|trans }}</h2>
            <p class="mt-4 text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{{ 'about.why.sub'|trans }}</p>
        </div>
        <div class="mt-12 grid md:grid-cols-2 gap-5">
            {% for n in 1..4 %}
                <article class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <h3 class="font-semibold tracking-tight text-lg">{{ ('about.why.p' ~ n ~ '_title')|trans }}</h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('about.why.p' ~ n ~ '_body')|trans }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Non-custodial promise ─── #}
<section class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-4xl px-6 py-20 text-center">
        <span class="inline-grid h-14 w-14 place-items-center rounded-2xl bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <h2 class="mt-5 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.custody.title'|trans }}</h2>
        <p class="mt-5 text-base text-slate-600 dark:text-slate-400 leading-relaxed">{{ 'about.custody.body'|trans }}</p>
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-500 leading-relaxed">{{ 'about.custody.detail'|trans }}</p>
    </div>
</section>

{# ─── Who it's for ─── #}
<section class="relative">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'about.who.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.who.title'|trans }}</h2>
        </div>
        <div class="mt-12 grid lg:grid-cols-3 gap-5">
            {% for n in 1..3 %}
                <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <h3 class="font-semibold tracking-tight text-lg">{{ ('about.who.p' ~ n ~ '_title')|trans }}</h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('about.who.p' ~ n ~ '_body')|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Final CTA ─── #}
<section class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
        <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'about.cta.title'|trans }}</h2>
        <p class="mt-4 text-base text-slate-600 dark:text-slate-400 leading-relaxed">{{ 'about.cta.sub'|trans }}</p>
        <div class="mt-8">
            <a href="{{ path('auth_register', {_locale: locale}) }}"
               class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-6 py-3 text-base font-semibold shadow-card transition">
                {{ 'about.cta.button'|trans }}
            </a>
        </div>
    </div>
</section>

{% endblock %}
