<ul>
    <li><strong>{{ 'privacy.s1_item_account_t'|trans }}</strong> — {{ 'privacy.s1_item_account_d'|trans }}</li>
    <li><strong>{{ 'privacy.s1_item_invoice_t'|trans }}</strong> — {{ 'privacy.s1_item_invoice_d'|trans }}</li>
    <li><strong>{{ 'privacy.s1_item_wallet_t'|trans }}</strong> — {{ 'privacy.s1_item_wallet_d'|trans }}</li>
    <li><strong>{{ 'privacy.s1_item_logs_t'|trans }}</strong> — {{ 'privacy.s1_item_logs_d'|trans }}</li>
</ul>

<h2>{{ 'privacy.s2_title'|trans }}</h2>
<p>{{ 'privacy.s2_body'|trans|raw }}</p>
<ul>
    <li>{{ 'privacy.s2_item_1'|trans|raw }}</li>
    <li>{{ 'privacy.s2_item_2'|trans|raw }}</li>
    <li>{{ 'privacy.s2_item_3'|trans|raw }}</li>
</ul>

