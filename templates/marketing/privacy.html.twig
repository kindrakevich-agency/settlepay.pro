{% extends 'marketing/_legal_layout.html.twig' %}

{% block title %}{{ 'privacy.seo.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'privacy.seo.description'|trans }}{% endblock %}

{% block legal_title %}{{ 'privacy.title'|trans }}{% endblock %}

{% block legal_body %}
<p>{{ 'privacy.intro'|trans|raw }}</p>

<h2>{{ 'privacy.s1_title'|trans }}</h2>
