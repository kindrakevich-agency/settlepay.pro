    <li><strong>Reown (WalletConnect)</strong> — {{ 'privacy.s3_walletconnect'|trans }}</li>
    <li><strong>{{ 'privacy.s3_chain_t'|trans }}</strong> — {{ 'privacy.s3_chain_d'|trans }}</li>
</ul>

<h2>{{ 'privacy.s4_title'|trans }}</h2>
