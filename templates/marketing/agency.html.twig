{% extends 'marketing/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'agency.seo.title'|trans }}{% endblock %}
{% block meta_description %}{{ 'agency.seo.description'|trans }}{% endblock %}

{% block marketing_content %}

{# ─── Hero ─── #}
<section class="relative overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true"
         style="background-image: radial-gradient(at 30% 20%, rgba(13,148,136,0.20) 0px, transparent 50%), radial-gradient(at 70% 60%, rgba(45,212,191,0.12) 0px, transparent 50%);"></div>
    <div class="relative mx-auto max-w-5xl px-6 pt-20 pb-12 text-center">
        <p class="text-sm font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'agency.eyebrow'|trans }}</p>
        <h1 class="mt-3 font-display text-4xl sm:text-5xl md:text-6xl font-semibold tracking-tight">{{ 'agency.hero.title'|trans }}</h1>
        <p class="mt-5 text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{{ 'agency.hero.sub'|trans }}</p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            {% if app.user %}
                <form method="POST" action="{{ path('dashboard_billing_upgrade', {_locale: locale, kind: 'agency'}) }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-upgrade') }}">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 text-sm font-semibold shadow-card transition">
                        {{ 'agency.hero.cta_primary'|trans }}
                    </button>
                </form>
            {% else %}
                <a href="{{ path('auth_register', {_locale: locale}) }}"
                   class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 text-sm font-semibold shadow-card transition">
                    {{ 'agency.hero.cta_primary'|trans }}
                </a>
            {% endif %}
            <a href="#how" class="inline-flex items-center gap-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur px-5 py-3 text-sm font-medium hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                {{ 'agency.hero.cta_secondary'|trans }}
            </a>
        </div>

        <p class="mt-6 text-xs text-slate-500 dark:text-slate-500">{{ 'agency.hero.trust'|trans }}</p>
    </div>
</section>

{# ─── How it works for agencies ─── #}
<section id="how" class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'agency.how.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'agency.how.title'|trans }}</h2>
            <p class="mt-4 text-base text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">{{ 'agency.how.sub'|trans }}</p>
        </div>

        <div class="mt-12 grid lg:grid-cols-3 gap-5">
            {% for n in 1..3 %}
                <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400 font-display text-lg font-semibold">{{ n }}</span>
                    <h3 class="mt-5 font-semibold tracking-tight">{{ ('agency.how.step' ~ n ~ '_title')|trans }}</h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('agency.how.step' ~ n ~ '_body')|trans }}</p>
                </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Features (agency-specific) ─── #}
<section class="relative">
    <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="text-center">
            <p class="text-xs font-medium text-brand-600 dark:text-brand-400 uppercase tracking-wide">{{ 'agency.features.eyebrow'|trans }}</p>
            <h2 class="mt-3 font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'agency.features.title'|trans }}</h2>
        </div>

        <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {% set feat_icons = ['users', 'shield', 'palette', 'webhook', 'wallet', 'support'] %}
            {% for n in 1..6 %}
                <article class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card">
                    <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400">
                        {% if feat_icons[n - 1] == 'users' %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        {% elseif feat_icons[n - 1] == 'shield' %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        {% elseif feat_icons[n - 1] == 'palette' %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="13.5" cy="6.5" r=".5"/><circle cx="17.5" cy="10.5" r=".5"/><circle cx="8.5" cy="7.5" r=".5"/><circle cx="6.5" cy="12.5" r=".5"/><path d="M12 2a10 10 0 1 0 0 20 2.5 2.5 0 0 0 0-5 2.5 2.5 0 0 1 0-5h2a8 8 0 0 0-2-10z"/></svg>
                        {% elseif feat_icons[n - 1] == 'webhook' %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="m18 16.98 1.84-3.18a4 4 0 1 0-6.88 0L8 21.5M11.84 9.02 8 15.5h6.16a4 4 0 0 1 0 8 4 4 0 0 1-4-4"/></svg>
                        {% elseif feat_icons[n - 1] == 'wallet' %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M19 7V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-2"/><path d="M21 11h-6a2 2 0 1 0 0 4h6z"/></svg>
                        {% else %}
                            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        {% endif %}
                    </span>
                    <h3 class="mt-5 font-semibold tracking-tight">{{ ('agency.features.f' ~ n ~ '_title')|trans }}</h3>
                    <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ ('agency.features.f' ~ n ~ '_body')|trans }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Pricing card ─── #}
<section class="relative bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-3xl px-6 py-20">
        <div class="relative rounded-3xl border-2 border-brand-500 bg-white dark:bg-slate-900 p-8 lg:p-10 shadow-card">
            <span class="absolute -top-3 left-8 inline-flex items-center rounded-full bg-brand-600 text-white px-3 py-1 text-xs font-semibold uppercase tracking-wide">{{ 'agency.pricing.badge'|trans }}</span>
            <div class="flex flex-wrap items-baseline justify-between gap-4">
                <div>
                    <h2 class="font-display text-2xl font-semibold tracking-tight">{{ 'agency.pricing.name'|trans }}</h2>
                    <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{{ 'agency.pricing.tagline'|trans }}</p>
                </div>
                <p class="font-display text-5xl font-semibold tracking-tight tabular-nums">$49<span class="text-base font-normal text-slate-400 ml-1">/mo</span></p>
            </div>
            <ul class="mt-6 grid sm:grid-cols-2 gap-x-6 gap-y-2.5 text-sm text-slate-700 dark:text-slate-300">
                {% for n in 1..6 %}
                    <li class="flex items-start gap-2.5">
                        <svg class="h-4 w-4 mt-0.5 text-brand-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m5 12 5 5L20 7"/></svg>
                        {{ ('agency.pricing.feat_' ~ n)|trans }}
                    </li>
                {% endfor %}
            </ul>
            <p class="mt-6 text-xs text-slate-500 dark:text-slate-500">{{ 'agency.pricing.disclaimer'|trans }}</p>
            <div class="mt-6">
                {% if app.user %}
                    <form method="POST" action="{{ path('dashboard_billing_upgrade', {_locale: locale, kind: 'agency'}) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-upgrade') }}">
                        <button type="submit" class="w-full inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-3 text-sm font-semibold transition">
                            {{ 'agency.pricing.cta'|trans }}
                        </button>
                    </form>
                {% else %}
                    <a href="{{ path('auth_register', {_locale: locale}) }}"
                       class="w-full inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-3 text-sm font-semibold transition">
                        {{ 'agency.pricing.cta'|trans }}
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</section>

{# ─── FAQ ─── #}
<section class="relative">
    <div class="mx-auto max-w-3xl px-6 py-20">
        <h2 class="font-display text-3xl font-semibold tracking-tight text-center">{{ 'agency.faq.title'|trans }}</h2>
        <div class="mt-10 space-y-3">
            {% for n in 1..6 %}
                <details class="group rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-5 py-4">
                    <summary class="cursor-pointer flex items-center justify-between font-medium hover:text-brand-600 transition">
                        <span>{{ ('agency.faq.q' ~ n)|trans }}</span>
                        <svg class="h-4 w-4 text-slate-400 group-open:rotate-180 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="mt-3 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                        {{ ('agency.faq.a' ~ n)|trans|raw }}
                    </div>
                </details>
            {% endfor %}
        </div>
    </div>
</section>

{# ─── Final CTA ─── #}
<section class="relative bg-slate-50 dark:bg-slate-900/40 border-t border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-3xl px-6 py-20 text-center">
        <h2 class="font-display text-3xl sm:text-4xl font-semibold tracking-tight">{{ 'agency.cta.title'|trans }}</h2>
        <p class="mt-4 text-base text-slate-600 dark:text-slate-400">{{ 'agency.cta.sub'|trans }}</p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
            {% if app.user %}
                <form method="POST" action="{{ path('dashboard_billing_upgrade', {_locale: locale, kind: 'agency'}) }}">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-upgrade') }}">
                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 text-sm font-semibold shadow-card transition">
                        {{ 'agency.cta.primary'|trans }}
                    </button>
                </form>
            {% else %}
                <a href="{{ path('auth_register', {_locale: locale}) }}"
                   class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-5 py-3 text-sm font-semibold shadow-card transition">
                    {{ 'agency.cta.primary'|trans }}
                </a>
            {% endif %}
            <a href="{{ path('marketing_pricing', {_locale: locale}) }}"
               class="inline-flex items-center gap-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white/60 dark:bg-slate-900/60 backdrop-blur px-5 py-3 text-sm font-medium hover:bg-slate-100 dark:hover:bg-slate-800 transition">
                {{ 'agency.cta.secondary'|trans }}
            </a>
        </div>
    </div>
</section>

{% endblock %}
