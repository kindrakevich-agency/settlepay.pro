                    <div class="mt-10 text-center">
                        <p class="text-sm text-slate-500 dark:text-slate-400">{{ 'checkout_section.amount_due'|trans }}</p>
                        <p class="mt-2 font-display text-6xl font-semibold tracking-tight tabular-nums">$2,450<span class="text-3xl text-slate-400">.00</span></p>
                        <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{{ 'checkout_section.for'|trans }}</p>
                    </div>

                    <div class="mt-8 grid grid-cols-2 gap-3">
                        <div>
                            <div class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-2">{{ 'checkout_section.pay_with'|trans }}</div>
                            <div class="grid grid-cols-3 gap-2">
                                <div class="rounded-xl border-2 border-brand-500 bg-brand-50/60 dark:bg-brand-500/10 p-2.5 text-center">
                                    <div class="text-xs font-semibold text-brand-700 dark:text-brand-400">USDC</div>
                                </div>
                                <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-2.5 text-center">
                                    <div class="text-xs font-semibold">USDT</div>
                                </div>
                                <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-2.5 text-center">
                                    <div class="text-xs font-semibold">DAI</div>
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-2">{{ 'checkout_section.on_network'|trans }}</div>
