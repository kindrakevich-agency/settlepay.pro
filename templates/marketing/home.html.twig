                        </div>
                        <code class="mt-1.5 block font-mono text-sm text-slate-700 dark:text-slate-300 break-all">0x742d35Cc6634C0532925a3b844Bc9e7595f8Bf2c</code>
                    </div>

                    <button type="button" class="mt-8 w-full inline-flex items-center justify-center gap-2 rounded-2xl bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white py-4 text-base font-semibold shadow-card hover:shadow-card-hover transition">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M14 12h4M22 10v4"/></svg>
                        {{ 'payment.connect_wallet'|trans }}
