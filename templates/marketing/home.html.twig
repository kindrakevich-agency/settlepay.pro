                    <p class="mt-3 text-center text-xs text-slate-500 dark:text-slate-500">{{ 'checkout_section.disclaimer'|trans }}</p>

                    <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-center gap-6 text-xs text-slate-400 dark:text-slate-500">
                        <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> {{ 'checkout_section.trust_one'|trans }}</span>
                        <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> {{ 'checkout_section.trust_two'|trans }}</span>
                        <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> {{ 'checkout_section.trust_three'|trans }}</span>
                    </div>
                </div>
            </div>

            <aside class="lg:col-span-5 order-1 lg:order-2 lg:pt-4 space-y-3">
                <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">{{ 'checkout_section.states_label'|trans }}</p>

                <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-4 flex items-start gap-3">
                    <span class="mt-1 grid h-6 w-6 place-items-center rounded-full bg-slate-100 dark:bg-slate-800 text-slate-500 text-xs font-semibold">1</span>
                    <div class="flex-1">
                        <p class="font-medium text-sm">{{ 'checkout_section.state1_title'|trans }}</p>
                        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">{{ 'checkout_section.state1_sub'|trans }}</p>
                    </div>
                </div>

                <div class="rounded-xl border-2 border-brand-500 bg-brand-50/40 dark:bg-brand-500/10 p-4 flex items-start gap-3">
                    <span class="mt-1 grid h-6 w-6 place-items-center rounded-full bg-brand-500 text-white text-xs font-semibold animate-pulse">2</span>
                    <div class="flex-1">
                        <p class="font-medium text-sm">{{ 'checkout_section.state2_title'|trans }}</p>
                        <p class="mt-0.5 text-xs text-slate-600 dark:text-slate-400">{{ 'checkout_section.state2_sub'|trans }}</p>
                        <div class="mt-2.5 h-1.5 w-full rounded-full bg-brand-100 dark:bg-brand-950 overflow-hidden">
                            <div class="h-full w-2/5 rounded-full bg-brand-500"></div>
                        </div>
                    </div>
                </div>

                <div class="rounded-xl border border-success-200 dark:border-success-500/30 bg-success-50 dark:bg-success-500/10 p-4 flex items-start gap-3">
                    <span class="mt-1 grid h-6 w-6 place-items-center rounded-full bg-success-500 text-white">
                        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                    </span>
                    <div class="flex-1">
                        <p class="font-medium text-sm text-success-700 dark:text-success-500">{{ 'checkout_section.state3_title'|trans }}</p>
                        <p class="mt-0.5 text-xs text-success-600/80 dark:text-success-500/80">{{ 'checkout_section.state3_sub'|trans }}</p>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>


