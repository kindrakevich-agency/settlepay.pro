{% extends 'base.html.twig' %}

{% block body %}
<header class="sticky top-0 z-40 border-b border-slate-200/70 dark:border-slate-800/70 bg-white/80 dark:bg-slate-950/80 backdrop-blur">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3.5">
        <a href="{{ path('marketing_home') }}" class="flex items-center gap-2.5">
            <span class="grid h-8 w-8 place-items-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 shadow-card">
                <svg class="h-4 w-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
            <span class="font-display text-lg font-semibold tracking-tight">{{ 'common.app_name'|trans }}</span>
        </a>
        <div class="flex items-center gap-2">
            <a href="#" class="hidden sm:inline-flex rounded-lg px-3 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition">
                {{ 'common.sign_in'|trans }}
            </a>
            <a href="#" class="inline-flex items-center gap-1.5 rounded-lg bg-slate-900 dark:bg-white px-3.5 py-2 text-sm font-medium text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 transition">
                {{ 'common.sign_up'|trans }}
            </a>
        </div>
    </div>
</header>

<section class="relative overflow-hidden">
    <div class="relative mx-auto max-w-7xl px-6 pt-20 pb-24 lg:pt-28 lg:pb-32">
        <div class="max-w-3xl">
            <span class="inline-flex items-center gap-2 rounded-full border border-brand-200/70 dark:border-brand-800/70 bg-brand-50/60 dark:bg-brand-950/40 px-3 py-1 text-xs font-medium text-brand-700 dark:text-brand-300">
                <span class="h-1.5 w-1.5 rounded-full bg-brand-500 animate-pulse-dot"></span>
                Live on Base · Polygon · Arbitrum · Optimism
            </span>

            <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.05]">
                {{ 'common.tagline'|trans }}
            </h1>

            <div class="mt-8 flex flex-wrap items-center gap-3">
                <a href="#" class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white px-5 py-3 text-sm font-medium shadow-card hover:shadow-card-hover transition">
                    {{ 'common.cta_primary'|trans }}
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a href="#" class="inline-flex items-center gap-2 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 px-5 py-3 text-sm font-medium text-slate-900 dark:text-slate-100 hover:bg-slate-50 dark:hover:bg-slate-800/60 transition shadow-xs">
                    {{ 'common.cta_secondary'|trans }}
                </a>
            </div>
        </div>
    </div>
</section>

<footer class="border-t border-slate-200 dark:border-slate-800">
    <div class="mx-auto max-w-7xl px-6 py-10 flex flex-wrap items-center justify-between gap-4">
        <span class="text-sm text-slate-600 dark:text-slate-400">© 2026 {{ 'common.app_name'|trans }}</span>
        <div class="flex items-center gap-4 text-xs">
            <a href="{{ path('marketing_home', {_locale: 'en'}) }}" class="hover:text-brand-600">EN</a>
            <a href="{{ path('marketing_home', {_locale: 'uk'}) }}" class="hover:text-brand-600">UK</a>
            <a href="{{ path('marketing_home', {_locale: 'es'}) }}" class="hover:text-brand-600">ES</a>
        </div>
    </div>
</footer>
{% endblock %}
