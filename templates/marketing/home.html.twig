                    <div>
                        <p class="text-sm font-semibold">{{ 'agency_teaser.workspace_demo'|trans }}</p>
                        <p class="text-xs text-slate-500 dark:text-slate-500">{{ 'agency_teaser.workspace_seats'|trans({'%used%': 7, '%limit%': 10}) }}</p>
                    </div>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 dark:bg-brand-500/10 text-brand-700 dark:text-brand-400 px-2.5 py-0.5 text-xs font-medium">
                        <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
                        Agency
                    </span>
                </div>

                <ul class="space-y-2">
                    {% set demo_members = [
                        {name: 'Vitalii K.',     role_key: 'agency_teaser.role_owner',  initials: 'VK', tone: 'brand'},
                        {name: 'Anna B.',        role_key: 'agency_teaser.role_member', initials: 'AB'},
                        {name: 'Marcus L.',      role_key: 'agency_teaser.role_member', initials: 'ML'},
                        {name: 'Sofia R.',       role_key: 'agency_teaser.role_member', initials: 'SR'},
                        {name: 'Yuki T.',        role_key: 'agency_teaser.role_member', initials: 'YT'},
                        {name: 'Diego C.',       role_key: 'agency_teaser.role_member', initials: 'DC'},
                        {name: 'Olha M.',        role_key: 'agency_teaser.role_member', initials: 'OM'}
                    ] %}
                    {% for m in demo_members %}
                        <li class="flex items-center gap-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-3 py-2">
                            <span class="grid h-9 w-9 place-items-center rounded-lg text-xs font-semibold
                                         {% if m.tone is defined %}bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400
                                         {% else %}bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300{% endif %}">
                                {{ m.initials }}
                            </span>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium truncate">{{ m.name }}</p>
                                <p class="text-xs text-slate-500 dark:text-slate-500">{{ m.role_key|trans }}</p>
