                </div>
                <h3 class="mt-5 font-semibold tracking-tight">{{ 'features.two.title'|trans }}</h3>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">{{ 'features.two.body'|trans }}</p>
            </article>
            <article class="group rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6 shadow-card hover:shadow-card-hover transition-shadow">
                <div class="grid h-10 w-10 place-items-center rounded-xl bg-success-50 dark:bg-success-500/10 text-success-600 dark:text-success-500">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
