{% extends 'base.html.twig' %}
{% from '_logo.html.twig' import logo %}

{% set locale = app.request.locale|default('en') %}
{% set seo_indexable = false %}

{% block title %}{{ 'invitations.invalid_title'|trans }} · Settlepay{% endblock %}

{% block body %}
<div class="min-h-dvh bg-slate-50 dark:bg-slate-950 grid place-items-center px-6 py-10">
    <div class="absolute top-0 inset-x-0 px-6 py-4">
        <a href="{{ path('marketing_home', {_locale: locale}) }}" aria-label="settlepay">{{ logo(size='sm') }}</a>
    </div>
    <main class="w-full max-w-md text-center">
        <div class="rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 lg:p-10 shadow-card">
            <span class="inline-grid h-14 w-14 place-items-center rounded-full bg-danger-50 dark:bg-danger-500/10 text-danger-500 text-2xl font-semibold">!</span>
            <h1 class="mt-5 font-display text-2xl font-semibold tracking-tight">{{ 'invitations.invalid_title'|trans }}</h1>
            <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
                {{ ('invitations.invalid_reason.' ~ reason)|trans }}
            </p>
            <a href="{{ path('marketing_home', {_locale: locale}) }}"
               class="mt-6 inline-flex items-center justify-center rounded-xl bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2.5 text-sm font-medium hover:bg-slate-800 dark:hover:bg-slate-100 transition">
                {{ 'invitations.back_home'|trans }}
            </a>
        </div>
    </main>
</div>
{% endblock %}
