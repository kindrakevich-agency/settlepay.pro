{% extends 'base.html.twig' %}
{% from '_logo.html.twig' import logo %}

{% set locale        = app.request.locale|default('en') %}
{% set is_paid       = invoice.status.value == 'paid' %}
{% set is_payable    = invoice.payable %}
{% set seo_indexable = false %}{# Public payment URLs must never appear in search index — they contain a UUID that's effectively a credential. #}

{% block title %}{{ 'payment.connect_wallet'|trans }} · {{ invoice.number }} · {{ invoice.user.businessName|default('Settlepay') }}{% endblock %}

{% block javascripts %}
    {# Bootstrap data for the wallet front-end. Lives in a JSON island so we
       never sprinkle PHP into JS string concatenation. #}
    <script type="application/json" id="settlepay-checkout-data">
        {
            "invoice": {
                "uuid":     {{ invoice.uuid|json_encode|raw }},
                "number":   {{ invoice.number|json_encode|raw }},
                "status":   {{ invoice.status.value|json_encode|raw }},
                "amount_cents": {{ invoice.amountCents }},
                "currency": {{ invoice.currency|json_encode|raw }},
                "recipient_address": {{ invoice.recipientAddress|json_encode|raw }},
                "due_date": {{ invoice.dueDate ? invoice.dueDate|date('Y-m-d')|json_encode|raw : 'null' }}
            },
            "available_chains": {{ available_chains|json_encode|raw }},
            "polling": { "url": "/api/v1/public/invoices/{{ invoice.uuid }}", "interval_ms": 5000 },
            "tx_endpoint": "/api/v1/public/invoices/{{ invoice.uuid }}/tx"
        }
    </script>
{% endblock %}

{% block body %}
<div class="min-h-dvh bg-slate-50 dark:bg-slate-950 grid place-items-center px-6 py-10">
    {# ─── Top mini-bar (logo + locale only — no nav) ───────────── #}
    <div class="absolute top-0 inset-x-0 px-6 py-4 flex items-center justify-between">
        <a href="{{ path('marketing_home') }}" aria-label="settlepay">
            {{ logo(size='sm') }}
        </a>
        <div class="flex items-center rounded-lg border border-slate-200 dark:border-slate-800 p-0.5 text-xs font-medium bg-white/80 dark:bg-slate-900/80 backdrop-blur">
            {% for code in ['en', 'uk', 'es'] %}
                {% set active = locale == code %}
                <a href="{{ path('public_payment_checkout', {_locale: code, uuid: invoice.uuid}) }}"
                   class="rounded-md px-2 py-1 transition
                          {{ active
                              ? 'bg-slate-900 text-white dark:bg-white dark:text-slate-900'
                              : 'text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100' }}">
                    {{ code|upper }}
                </a>
            {% endfor %}
        </div>
    </div>

    {# ─── The card ─────────────────────────────────────────────── #}
    <main class="relative w-full max-w-md">
        <div class="absolute -inset-6 rounded-3xl blur-2xl opacity-50 pointer-events-none" aria-hidden="true"
             style="background-image: radial-gradient(at 20% 30%, rgba(45,212,191,0.30) 0px, transparent 50%), radial-gradient(at 80% 70%, rgba(13,148,136,0.25) 0px, transparent 50%);"></div>

        <div class="relative rounded-3xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8 lg:p-10 shadow-pop animate-fade-in">

            {# Header: business + status pill #}
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-2.5">
                    {% if invoice.user.brandLogoPath %}
                        <img src="/{{ invoice.user.brandLogoPath }}"
                             alt="{{ invoice.user.businessName }}"
                             class="h-9 w-9 rounded-xl object-cover bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                    {% else %}
                        <span class="grid h-9 w-9 place-items-center rounded-xl text-white text-sm font-semibold"
                              style="background: {{ invoice.user.brandColor ? invoice.user.brandColor : 'linear-gradient(135deg, #2dd4bf, #0f766e)' }};">
                            {{ (invoice.user.businessName|default('S'))|slice(0, 2)|upper }}
                        </span>
                    {% endif %}
                    <div>
                        <div class="text-sm font-semibold">{{ invoice.user.businessName|default('Settlepay merchant') }}</div>
                        <div class="text-xs text-slate-500 dark:text-slate-500">
                            {{ 'checkout_section.invoice_from'|trans }} · <span class="font-mono">{{ invoice.number }}</span>
                        </div>
                    </div>
                </div>
                {% if is_paid %}
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-success-50 dark:bg-success-500/10 px-2.5 py-0.5 text-xs font-medium text-success-600 dark:text-success-500">
                        <span class="h-1.5 w-1.5 rounded-full bg-success-500"></span>
                        {{ 'invoice.status.paid'|trans }}
                    </span>
                {% endif %}
            </div>

            {# Amount focus #}
            <div class="mt-10 text-center">
                <p class="text-sm text-slate-500 dark:text-slate-400">{{ 'checkout_section.amount_due'|trans }}</p>
                {% set amount_parts = amount_decimal|split('.') %}
                <p class="mt-2 font-display text-6xl font-semibold tracking-tight tabular-nums">
                    {%- if invoice.currency == 'USD' -%}<span class="text-slate-400">$</span>{%- endif -%}
                    {{ amount_parts[0]|number_format(0, '.', ',') }}<span class="text-3xl text-slate-400">.{{ amount_parts[1] ?? '00' }}</span>
                </p>
                {% if invoice.description %}
                    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{{ invoice.description }}{% if invoice.dueDate %} · {{ 'invoice.due_date'|trans }}: {{ invoice.dueDate|format_date('medium', locale=locale) }}{% endif %}</p>
                {% endif %}
            </div>

            {# Line items (collapsible micro-detail) #}
            {% if invoice.lineItems|length > 0 %}
                <details class="mt-6 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/60">
                    <summary class="cursor-pointer select-none px-4 py-2.5 text-xs font-medium text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 transition">
                        {{ invoice.lineItems|length }} {% if invoice.lineItems|length == 1 %}line item{% else %}line items{% endif %}
                    </summary>
                    <ul class="px-4 pb-3 pt-1 space-y-1.5 text-sm border-t border-slate-200 dark:border-slate-800">
                        {% for item in invoice.lineItems %}
                            <li class="flex justify-between">
                                <span class="text-slate-600 dark:text-slate-400">{{ item.description }}</span>
                                <span class="font-medium tabular-nums">${{ (item.totalCents / 100)|number_format(2, '.', ',') }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </details>
            {% endif %}

            {# Token + chain selector — populated by JS based on available_chains #}
            <div class="mt-8 grid grid-cols-2 gap-3" data-checkout-selectors>
                <fieldset>
                    <legend class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-2">{{ 'checkout_section.pay_with'|trans }}</legend>
                    <div class="grid grid-cols-3 gap-2" data-token-selector>
                        {% for token in invoice.acceptedTokens %}
                            <label class="cursor-pointer rounded-xl border {{ loop.first ? 'border-2 border-brand-500 bg-brand-50/60 dark:bg-brand-500/10' : 'border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-slate-300 dark:hover:border-slate-700' }} p-2.5 text-center transition">
                                <input type="radio" name="token" value="{{ token }}" class="sr-only" {% if loop.first %}checked{% endif %}>
                                <div class="text-xs font-semibold {{ loop.first ? 'text-brand-700 dark:text-brand-400' : '' }}">{{ token }}</div>
                            </label>
                        {% endfor %}
                    </div>
                </fieldset>

                <fieldset>
                    <legend class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-2">{{ 'checkout_section.on_network'|trans }}</legend>
                    <select name="chain" class="block w-full rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-3 py-2.5 text-sm" data-chain-selector>
                        {% for chain in available_chains %}
                            <option value="{{ chain.chain_id }}">{{ chain.name }}</option>
                        {% endfor %}
                    </select>
                </fieldset>
            </div>

            {# Recipient address #}
            <div class="mt-6 rounded-xl bg-slate-50 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800 p-4">
                <div class="flex items-center justify-between">
                    <span class="text-xs font-medium text-slate-500 dark:text-slate-400">{{ 'checkout_section.pays_to'|trans }}</span>
                    <span class="text-xs text-slate-400">{{ 'checkout_section.verified'|trans }}</span>
                </div>
                <code class="mt-1.5 block font-mono text-sm text-slate-700 dark:text-slate-300 break-all">{{ invoice.recipientAddress }}</code>
            </div>

            {# Connect / Pay button — Stage 2/3 wires it. Stage 1 is a stub. #}
            <button id="settlepay-cta"
                    type="button"
                    class="mt-8 w-full inline-flex items-center justify-center gap-2 rounded-2xl {{ invoice.user.brandColor ? '' : 'bg-brand-600 hover:bg-brand-700 active:bg-brand-800' }} text-white py-4 text-base font-semibold shadow-card hover:shadow-card-hover transition disabled:opacity-50 disabled:cursor-not-allowed"
                    {% if invoice.user.brandColor %}style="background-color: {{ invoice.user.brandColor }}"{% endif %}
                    {% if not is_payable %}disabled{% endif %}>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                    <rect x="2" y="6" width="20" height="14" rx="2"/><path d="M14 12h4M22 10v4"/>
                </svg>
                <span data-cta-label>
                    {% if is_paid %}{{ 'payment.success_title'|trans }}
                    {% elseif not is_payable %}{{ 'invoice.status.' ~ invoice.status.value|replace({'_': '-'})|default('void')|trans }}
                    {% else %}{{ 'payment.connect_wallet'|trans }}
                    {% endif %}
                </span>
            </button>

            <p class="mt-3 text-center text-xs text-slate-500 dark:text-slate-500">
                {{ 'checkout_section.disclaimer'|trans }}
            </p>

            {# Status panel — JS toggles visibility + tone (pending / success / error) based on tx state. #}
            <div id="settlepay-status" data-tone="pending"
                 class="mt-6 hidden rounded-xl border border-brand-200 dark:border-brand-700/50 bg-brand-50/60 dark:bg-brand-500/10 p-4 text-sm">
                <div class="flex items-center gap-2">
                    {# Pending: animated spinner. Hidden via JS when tone flips to success/error. #}
                    <svg data-status-icon-pending class="h-4 w-4 animate-spin text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12a9 9 0 1 1-6.2-8.5"/></svg>
                    {# Success: green check. Shown by JS when tone === success. #}
                    <svg data-status-icon-success class="h-4 w-4 text-success-600 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                    {# Error: red X. Shown by JS when tone === error. #}
                    <svg data-status-icon-error class="h-4 w-4 text-danger-600 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
                    <span data-status-text>{{ 'payment.confirming'|trans }}</span>
                </div>
                <div data-status-progress-wrap class="mt-2 h-1.5 w-full rounded-full bg-brand-100 dark:bg-brand-950 overflow-hidden">
                    <div data-status-bar class="h-full w-0 rounded-full bg-brand-500 transition-all"></div>
                </div>
                <code data-status-tx class="mt-2 block font-mono text-xs text-slate-500 truncate"></code>
            </div>

            {# Trust micro-row #}
            <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800 flex items-center justify-center gap-6 text-xs text-slate-400 dark:text-slate-500">
                <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg> {{ 'checkout_section.trust_one'|trans }}</span>
                <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> {{ 'checkout_section.trust_two'|trans }}</span>
                <span class="flex items-center gap-1.5"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> {{ 'checkout_section.trust_three'|trans }}</span>
            </div>
        </div>
    </main>
</div>

{# Vite-loaded checkout bundle (Stage 2/3 wires the wallet flow into the elements above). #}
{{ vite_entry_script('assets/checkout/checkout.ts') }}
{% endblock %}
