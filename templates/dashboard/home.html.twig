{% extends 'base.html.twig' %}
{% from '_logo.html.twig' import logo %}

{% set locale = app.request.locale|default('en') %}

{% block title %}{{ 'nav.dashboard'|trans }} · Settlepay{% endblock %}

{% block body %}
<div class="min-h-dvh bg-slate-50 dark:bg-slate-950">
    {# Stripped-down topbar — full sidebar comes with the React SPA milestone. #}
    <header class="border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5">
            <a href="{{ path('marketing_home', {_locale: locale}) }}" aria-label="settlepay">{{ logo(size='sm') }}</a>
            <div class="flex items-center gap-3 text-sm">
                <span class="text-slate-500 dark:text-slate-400">{{ user.email }}</span>
                <a href="{{ path('auth_logout', {_locale: locale}) }}"
                   class="rounded-lg border border-slate-200 dark:border-slate-800 px-3 py-1.5 text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition">
                    {{ 'common.log_out'|trans }}
                </a>
            </div>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-12">
        <h1 class="font-display text-3xl font-semibold tracking-tight">{{ 'dashboard.welcome_title'|trans({'%name%': user.displayName ?? (user.email|split('@')|first)}) }}</h1>
        <p class="mt-2 text-slate-600 dark:text-slate-400">{{ 'dashboard.welcome_sub'|trans }}</p>

        {% if verification_needed %}
            <div class="mt-6 rounded-2xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-5 flex gap-3">
                <span class="grid h-6 w-6 shrink-0 mt-0.5 place-items-center rounded-full bg-warning-500 text-white text-xs font-bold">!</span>
                <div class="flex-1 text-sm">
                    <p class="font-medium text-warning-700 dark:text-warning-500">{{ 'dashboard.verify_title'|trans }}</p>
                    <p class="text-warning-700/80 dark:text-warning-500/80">{{ 'dashboard.verify_sub'|trans({'%email%': user.email}) }}</p>
                </div>
            </div>
        {% endif %}

        <div class="mt-10 rounded-3xl border-2 border-dashed border-slate-200 dark:border-slate-800 p-12 text-center">
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-brand-50 dark:bg-brand-500/10 text-brand-600 dark:text-brand-400">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
            </div>
            <h2 class="mt-4 font-display text-lg font-semibold tracking-tight">{{ 'dashboard.empty_title'|trans }}</h2>
            <p class="mt-1.5 text-sm text-slate-600 dark:text-slate-400 max-w-md mx-auto">{{ 'dashboard.empty_sub'|trans }}</p>
            <p class="mt-3 text-xs text-slate-500 dark:text-slate-500">{{ 'dashboard.empty_coming'|trans }}</p>
        </div>
    </main>
</div>
{% endblock %}
