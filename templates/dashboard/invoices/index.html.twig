{% extends 'dashboard/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block dashboard_title %}{{ 'nav.invoices'|trans }}{% endblock %}

{% block dashboard_content %}
    <div class="flex items-center justify-between flex-wrap gap-4 mb-6">
        <h1 class="font-display text-2xl sm:text-3xl font-semibold tracking-tight">
            {{ 'nav.invoices'|trans }} <span class="text-slate-400 dark:text-slate-600 font-normal text-xl">{{ total }}</span>
        </h1>
        <a href="{{ path('dashboard_invoice_new', {_locale: locale}) }}"
           class="inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white px-4 py-2.5 text-sm font-medium shadow-card hover:shadow-card-hover transition">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            {{ 'invoice.new'|trans }}
        </a>
    </div>

    {# Filter bar #}
    <form method="GET" class="mb-5 flex flex-wrap gap-2 items-center">
        <div class="relative flex-1 min-w-[200px]">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="search" name="q" value="{{ search }}"
                   placeholder="{{ 'invoice.search_placeholder'|trans }}"
                   class="w-full pl-9 pr-3 py-2 text-sm rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition">
        </div>
        <select name="status" class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-3 py-2 text-sm">
            <option value="">{{ 'invoice.filter_all'|trans }}</option>
            {% for s in statuses %}
                <option value="{{ s }}" {{ s == status ? 'selected' : '' }}>{{ ('invoice.status.' ~ s)|trans }}</option>
            {% endfor %}
        </select>
        <button type="submit" class="rounded-xl bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium">{{ 'invoice.filter_apply'|trans }}</button>
        {% if search != '' or status != '' %}
            <a href="{{ path('dashboard_invoices', {_locale: locale}) }}" class="text-xs text-slate-500 dark:text-slate-400 hover:underline">{{ 'invoice.filter_clear'|trans }}</a>
        {% endif %}
    </form>

    {% if invoices|length == 0 %}
        <div class="rounded-2xl border-2 border-dashed border-slate-200 dark:border-slate-800 p-12 text-center">
            <h3 class="font-display text-lg font-semibold tracking-tight">{{ search != '' or status != '' ? 'invoice.empty_filtered'|trans : 'components_section.empty_title'|trans }}</h3>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'components_section.empty_sub'|trans }}</p>
            {% if search == '' and status == '' %}
                <a href="{{ path('dashboard_invoice_new', {_locale: locale}) }}"
                   class="mt-4 inline-flex items-center gap-2 rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-medium transition">
                    {{ 'invoice.new'|trans }}
                </a>
            {% endif %}
        </div>
    {% else %}
        <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="text-xs text-slate-500 dark:text-slate-400 bg-slate-50/60 dark:bg-slate-950/40">
                        <tr class="border-b border-slate-200 dark:border-slate-800">
                            <th class="text-left font-medium px-5 py-2.5">{{ 'dashboard_section.col_invoice'|trans }}</th>
                            <th class="text-left font-medium px-5 py-2.5">{{ 'invoice.client'|trans }}</th>
                            <th class="text-left font-medium px-5 py-2.5">{{ 'dashboard_section.col_status'|trans }}</th>
                            <th class="text-right font-medium px-5 py-2.5">{{ 'invoice.amount'|trans }}</th>
                            <th class="text-right font-medium px-5 py-2.5">{{ 'dashboard_section.col_due'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        {% for inv in invoices %}
                            {% set s = inv.status.value %}
                            {% set tone = {paid:'success', sent:'info', viewed:'warning', overdue:'danger', draft:'slate', void:'slate', refunded:'slate', partially_paid:'warning'}[s]|default('slate') %}
                            <tr class="hover:bg-slate-50/60 dark:hover:bg-slate-950/40 transition cursor-pointer"
                                onclick="location.href='{{ path('dashboard_invoice_show', {_locale: locale, uuid: inv.uuid}) }}'">
                                <td class="px-5 py-3.5 font-mono text-xs">{{ inv.number }}</td>
                                <td class="px-5 py-3.5">{{ inv.clientName }}</td>
                                <td class="px-5 py-3.5">
                                    <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-medium
                                                  {% if tone == 'success' %}bg-success-50 dark:bg-success-500/10 text-success-600
                                                  {% elseif tone == 'info' %}bg-info-50 dark:bg-info-500/10 text-info-600
                                                  {% elseif tone == 'warning' %}bg-warning-50 dark:bg-warning-500/10 text-warning-600
                                                  {% elseif tone == 'danger' %}bg-danger-50 dark:bg-danger-500/10 text-danger-600
                                                  {% else %}bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400{% endif %}">
                                        <span class="h-1.5 w-1.5 rounded-full
                                                     {% if tone == 'success' %}bg-success-500
                                                     {% elseif tone == 'info' %}bg-info-500
                                                     {% elseif tone == 'warning' %}bg-warning-500
                                                     {% elseif tone == 'danger' %}bg-danger-500
                                                     {% else %}bg-slate-400{% endif %}"></span>
                                        {{ ('invoice.status.' ~ s)|trans }}
                                    </span>
                                </td>
                                <td class="px-5 py-3.5 text-right font-medium tabular-nums">${{ (inv.amountCents / 100)|number_format(2, '.', ',') }}</td>
                                <td class="px-5 py-3.5 text-right {{ s == 'overdue' ? 'text-danger-600 dark:text-danger-500' : 'text-slate-500 dark:text-slate-400' }}">
                                    {% if inv.dueDate %}{{ inv.dueDate|format_date('medium', locale=locale) }}{% else %}—{% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if pages > 1 %}
            <div class="mt-5 flex items-center justify-between text-sm">
                <span class="text-slate-500 dark:text-slate-400">{{ 'invoice.pagination'|trans({'%page%': page, '%pages%': pages, '%total%': total}) }}</span>
                <div class="flex items-center gap-2">
                    {% if page > 1 %}
                        <a href="?{{ {page: page - 1, status: status, q: search}|filter(v => v != '')|url_encode }}"
                           class="rounded-lg border border-slate-200 dark:border-slate-800 px-3 py-1.5 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition">←</a>
                    {% endif %}
                    {% if page < pages %}
                        <a href="?{{ {page: page + 1, status: status, q: search}|filter(v => v != '')|url_encode }}"
                           class="rounded-lg border border-slate-200 dark:border-slate-800 px-3 py-1.5 hover:bg-slate-100 dark:hover:bg-slate-800/60 transition">→</a>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
