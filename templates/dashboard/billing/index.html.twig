{% extends 'dashboard/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block dashboard_title %}{{ 'billing.title'|trans }}{% endblock %}

{% block dashboard_content %}
<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <h1 class="font-display text-2xl sm:text-3xl font-semibold tracking-tight">{{ 'billing.title'|trans }}</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'billing.subtitle'|trans }}</p>
    </div>

    {% if not platform_enabled %}
        <div class="rounded-2xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-4 text-sm text-warning-700 dark:text-warning-500">
            <p class="font-medium">{{ 'billing.platform_unset_title'|trans }}</p>
            <p class="mt-1 text-warning-700/80 dark:text-warning-500/80">{{ 'billing.platform_unset_body'|trans }}</p>
        </div>
    {% endif %}

    {# ─── Current plan ─── #}
    <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
        <div class="flex items-center justify-between mb-4 flex-wrap gap-3">
            <h2 class="font-semibold tracking-tight">{{ 'billing.current_plan'|trans }}</h2>
            {% if user.pro %}
                <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 dark:bg-brand-500/10 text-brand-700 dark:text-brand-400 px-2.5 py-0.5 text-xs font-medium">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
                    {{ user.proLifetime ? 'billing.plan_pro_lifetime'|trans : 'billing.plan_pro_monthly'|trans }}
                </span>
            {% else %}
                <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 px-2.5 py-0.5 text-xs font-medium">
                    <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                    {{ 'billing.plan_free'|trans }}
                </span>
            {% endif %}
        </div>

        <div class="grid sm:grid-cols-3 gap-4 text-sm">
            <div>
                <div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">{{ 'billing.label_fee_rate'|trans }}</div>
                <div class="mt-1 font-mono tabular-nums">{{ user.pro ? '0.5%' : '1%' }}</div>
            </div>
            <div>
                <div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">{{ 'billing.label_volume'|trans }}</div>
                <div class="mt-1">{{ user.pro ? 'billing.unlimited'|trans : 'billing.volume_free'|trans }}</div>
            </div>
            <div>
                <div class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">{{ 'billing.label_renews'|trans }}</div>
                <div class="mt-1">
                    {% if user.proLifetime %}{{ 'billing.lifetime'|trans }}
                    {% elseif user.pro and user.planRenewsAt %}{{ user.planRenewsAt|date('Y-m-d') }}
                    {% else %}—{% endif %}
                </div>
            </div>
        </div>

        {% if user.pro and user.planRenewsAt %}
            {% if user.planCanceledAt %}
                <div class="mt-4 rounded-xl bg-slate-50 dark:bg-slate-950/60 border border-slate-200 dark:border-slate-800 p-3 text-xs text-slate-600 dark:text-slate-400">
                    {{ 'billing.canceled_notice'|trans({'%date%': user.planRenewsAt|date('Y-m-d')}) }}
                </div>
            {% else %}
                <form method="POST" action="{{ path('dashboard_billing_cancel', {_locale: locale}) }}" class="mt-4" onsubmit="return confirm('{{ 'billing.confirm_cancel'|trans|escape('js') }}')">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-cancel') }}">
                    <button type="submit" class="text-xs font-medium text-slate-500 dark:text-slate-500 hover:text-danger-600 dark:hover:text-danger-500 transition">
                        {{ 'billing.cancel_subscription'|trans }}
                    </button>
                </form>
            {% endif %}
        {% endif %}
    </section>

    {# ─── Free-plan volume meter — only shown when on Free ─── #}
    {% if not user.pro %}
        {% set pct = (mtd_volume_cents / free_cap_cents * 100)|round(0) %}
        {% set tone = pct >= 100 ? 'danger' : (pct >= 80 ? 'warning' : 'brand') %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
            <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
                <h2 class="font-semibold tracking-tight">{{ 'billing.volume_meter_title'|trans }}</h2>
                <span class="font-mono tabular-nums text-sm text-slate-600 dark:text-slate-400">
                    ${{ (mtd_volume_cents / 100)|number_format(2, '.', ',') }} / ${{ (free_cap_cents / 100)|number_format(0, '.', ',') }}
                </span>
            </div>
            <div class="h-2 w-full rounded-full bg-slate-100 dark:bg-slate-800 overflow-hidden">
                <div class="h-full rounded-full bg-{{ tone }}-500 transition-all" style="width: {{ pct > 100 ? 100 : pct }}%"></div>
            </div>
            <p class="mt-3 text-xs text-slate-500 dark:text-slate-400">
                {% if pct >= 100 %}
                    {{ 'billing.volume_meter_full'|trans }}
                {% else %}
                    {{ 'billing.volume_meter_remaining'|trans({'%amount%': (cap_remaining_cents / 100)|number_format(2, '.', ',')}) }}
                {% endif %}
            </p>
        </section>
    {% endif %}

    {# ─── Accumulated fees ─── #}
    <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
        <div class="flex items-center justify-between mb-3 flex-wrap gap-3">
            <h2 class="font-semibold tracking-tight">{{ 'billing.fees_owed'|trans }}</h2>
            <span class="font-mono tabular-nums text-2xl font-semibold">${{ (user.feesOwedCents / 100)|number_format(2, '.', ',') }}</span>
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-400">{{ 'billing.fees_owed_explainer'|trans }}</p>
        {% if user.feesOwedCents > 0 %}
            <form method="POST" action="{{ path('dashboard_billing_pay_fees', {_locale: locale}) }}" class="mt-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-pay-fees') }}">
                <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-4 py-2 text-sm font-medium hover:bg-slate-800 dark:hover:bg-slate-100 transition">
                    {{ 'billing.pay_fees_now'|trans({'%amount%': (user.feesOwedCents / 100)|number_format(2, '.', ',')}) }}
                </button>
            </form>
        {% endif %}
    </section>

    {# ─── Upgrade options (only show when not lifetime) ─── #}
    {% if not user.proLifetime %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-gradient-to-br from-brand-50/80 to-white dark:from-brand-950/30 dark:to-slate-900 p-6">
            <h2 class="font-display text-xl font-semibold tracking-tight">{{ 'billing.upgrade_title'|trans }}</h2>
            <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'billing.upgrade_sub'|trans }}</p>

            <div class="mt-5 grid sm:grid-cols-2 gap-4">
                {# Monthly card #}
                <form method="POST" action="{{ path('dashboard_billing_upgrade', {_locale: locale, kind: 'monthly'}) }}"
                      class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-upgrade') }}">
                    <div class="flex items-baseline gap-1.5">
                        <span class="font-display text-3xl font-semibold tracking-tight">${{ pro_monthly_usd }}</span>
                        <span class="text-sm text-slate-500 dark:text-slate-400">{{ 'billing.per_month'|trans }}</span>
                    </div>
                    <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">{{ 'billing.monthly_blurb'|trans }}</p>
                    <button type="submit" class="mt-5 w-full rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-medium transition">
                        {{ user.pro ? 'billing.renew_monthly'|trans : 'billing.upgrade_monthly'|trans }}
                    </button>
                </form>

                {# Lifetime card #}
                <form method="POST" action="{{ path('dashboard_billing_upgrade', {_locale: locale, kind: 'lifetime'}) }}"
                      class="relative rounded-2xl border-2 border-brand-500 bg-white dark:bg-slate-900 p-5 shadow-card">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('billing-upgrade') }}">
                    <span class="absolute -top-2.5 right-4 inline-flex items-center rounded-full bg-brand-600 text-white px-2.5 py-0.5 text-xs font-medium">
                        {{ 'billing.best_value'|trans }}
                    </span>
                    <div class="flex items-baseline gap-1.5">
                        <span class="font-display text-3xl font-semibold tracking-tight">${{ pro_lifetime_usd }}</span>
                        <span class="text-sm text-slate-500 dark:text-slate-400">{{ 'billing.one_time'|trans }}</span>
                    </div>
                    <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">{{ 'billing.lifetime_blurb'|trans({'%months%': (pro_lifetime_usd / pro_monthly_usd)|round(1, 'floor')}) }}</p>
                    <button type="submit" class="mt-5 w-full rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-medium transition">
                        {{ 'billing.upgrade_lifetime'|trans }}
                    </button>
                </form>
            </div>

            <p class="mt-4 text-xs text-slate-500 dark:text-slate-500">{{ 'billing.upgrade_disclaimer'|trans }}</p>
        </section>
    {% endif %}

</div>
{% endblock %}
