{% extends 'dashboard/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block dashboard_title %}{{ 'branding.title'|trans }}{% endblock %}

{% block dashboard_content %}
<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <a href="{{ path('dashboard_settings', {_locale: locale}) }}"
           class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            {{ 'nav.settings'|trans }}
        </a>
        <h1 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight">{{ 'branding.title'|trans }}</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'branding.subtitle'|trans }}</p>
    </div>

    {% if not user.pro %}
        <div class="rounded-2xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-4">
            <p class="text-sm font-medium text-warning-700 dark:text-warning-500">{{ 'branding.free_plan_required'|trans }}</p>
            <a href="{{ path('dashboard_billing', {_locale: locale}) }}"
               class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-3 py-1.5 text-xs font-medium transition">
                {{ 'billing.upgrade_title'|trans }}
            </a>
        </div>
    {% endif %}

    {# ─── Preview ─── #}
    <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
        <h2 class="font-semibold tracking-tight">{{ 'branding.preview_title'|trans }}</h2>
        <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{{ 'branding.preview_sub'|trans }}</p>

        <div class="mt-5 rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/60 p-6">
            <div class="flex items-center gap-3">
                {% if user.brandLogoPath %}
                    <img src="/{{ user.brandLogoPath }}" alt="{{ user.businessName }}" class="h-10 w-10 rounded-lg object-cover bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                {% else %}
                    <span class="grid h-10 w-10 place-items-center rounded-lg text-white text-sm font-semibold"
                          style="background-color: {{ user.brandColor ?: '#0d9488' }}">
                        {{ (user.businessName|default(user.email))|slice(0, 2)|upper }}
                    </span>
                {% endif %}
                <div>
                    <div class="font-semibold">{{ user.businessName ?: (user.email|split('@')|first) }}</div>
                    <div class="text-xs text-slate-500">{{ 'branding.preview_invoice_label'|trans }}</div>
                </div>
            </div>
            <button type="button"
                    class="mt-5 inline-flex items-center justify-center rounded-xl text-white px-4 py-2.5 text-sm font-medium"
                    style="background-color: {{ user.brandColor ?: '#0d9488' }}">
                {{ 'invoice.pay_now'|trans }}
            </button>
        </div>
    </section>

    {% if user.pro %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
            <form method="POST" action="{{ path('dashboard_branding_save', {_locale: locale}) }}"
                  enctype="multipart/form-data" class="space-y-5">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('branding-save') }}">

                <div>
                    <label for="brand_color" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'branding.color_label'|trans }}</label>
                    <div class="flex items-center gap-3">
                        <input type="color" name="brand_color" id="brand_color"
                               value="{{ user.brandColor ?: '#0d9488' }}"
                               class="h-10 w-16 rounded-lg border border-slate-200 dark:border-slate-700 cursor-pointer">
                        <input type="text" pattern="^#[0-9a-fA-F]{6}$" maxlength="7"
                               value="{{ user.brandColor ?: '#0d9488' }}"
                               oninput="document.getElementById('brand_color').value=this.value"
                               class="px-3 py-2 rounded-xl bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-700 font-mono text-sm w-32 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition">
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 dark:text-slate-400">{{ 'branding.color_hint'|trans }}</p>
                </div>

                <div>
                    <label for="brand_logo" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'branding.logo_label'|trans }}</label>
                    <input type="file" name="brand_logo" id="brand_logo"
                           accept="image/png,image/jpeg,image/svg+xml,image/webp"
                           class="block w-full text-sm text-slate-600 dark:text-slate-400
                                  file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0
                                  file:text-sm file:font-medium file:bg-slate-100 file:text-slate-700
                                  dark:file:bg-slate-800 dark:file:text-slate-200
                                  hover:file:bg-slate-200 dark:hover:file:bg-slate-700 cursor-pointer">
                    <p class="mt-1.5 text-xs text-slate-500 dark:text-slate-400">{{ 'branding.logo_hint'|trans }}</p>
                </div>

                <div class="flex justify-end pt-2">
                    <button type="submit"
                            class="inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-medium transition">
                        {{ 'branding.save'|trans }}
                    </button>
                </div>
            </form>

            {% if user.brandLogoPath %}
                <form method="POST" action="{{ path('dashboard_branding_remove', {_locale: locale}) }}"
                      onsubmit="return confirm('{{ 'branding.confirm_remove_logo'|trans|escape('js') }}')"
                      class="mt-4 pt-4 border-t border-slate-200 dark:border-slate-800">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('branding-remove') }}">
                    <button type="submit" class="text-xs font-medium text-danger-600 hover:text-danger-700 transition">
                        {{ 'branding.remove_logo'|trans }}
                    </button>
                </form>
            {% endif %}
        </section>
    {% endif %}

</div>
{% endblock %}
