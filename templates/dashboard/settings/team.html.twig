{% extends 'dashboard/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block dashboard_title %}{{ 'team.title'|trans }}{% endblock %}

{% block dashboard_content %}
<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <a href="{{ path('dashboard_settings', {_locale: locale}) }}"
           class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            {{ 'nav.settings'|trans }}
        </a>
        <h1 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight">{{ 'team.title'|trans }}</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'team.subtitle'|trans({'%workspace%': workspace.name}) }}</p>
    </div>

    {# ─── Plan + seat status banner ─── #}
    {% set used = members|length + invitations|length %}
    {% set remaining = workspace.seatLimit - used %}
    <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5 flex items-center justify-between gap-4 flex-wrap">
        <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-500">{{ 'team.seats'|trans }}</p>
            <p class="mt-1 font-mono tabular-nums text-lg font-semibold">{{ used }} / {{ workspace.seatLimit }}</p>
        </div>
        {% if not workspace.agency %}
            <a href="{{ path('dashboard_billing', {_locale: locale}) }}"
               class="rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-3.5 py-2 text-sm font-medium transition">
                {{ 'team.upgrade_to_agency'|trans }}
            </a>
        {% endif %}
    </div>

    {% if not workspace.agency %}
        <div class="rounded-2xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-4 text-sm text-warning-700 dark:text-warning-500">
            {{ 'team.agency_plan_required'|trans }}
        </div>
    {% endif %}

    {# ─── Invite form (owner only, Agency only) ─── #}
    {% if is_owner and workspace.agency %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
            <h2 class="font-semibold tracking-tight">{{ 'team.invite_title'|trans }}</h2>
            <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">{{ 'team.invite_hint'|trans }}</p>
            <form method="POST" action="{{ path('dashboard_team_invite', {_locale: locale}) }}" class="mt-4 flex flex-col sm:flex-row gap-3">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('team-invite') }}">
                <input type="email" name="email" required placeholder="{{ 'team.email_placeholder'|trans }}"
                       class="flex-1 px-3.5 py-2.5 rounded-xl bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-700 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition text-sm">
                <button type="submit" {% if remaining <= 0 %}disabled{% endif %}
                        class="inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed text-white px-4 py-2.5 text-sm font-medium transition">
                    {{ 'team.send_invite'|trans }}
                </button>
            </form>
            {% if remaining <= 0 %}
                <p class="mt-3 text-xs text-warning-600 dark:text-warning-500">{{ 'team.seat_limit_reached'|trans }}</p>
            {% endif %}
        </section>
    {% endif %}

    {# ─── Members ─── #}
    <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden">
        <header class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
            <h2 class="font-semibold tracking-tight">{{ 'team.members_title'|trans }}</h2>
        </header>
        <ul class="divide-y divide-slate-200 dark:divide-slate-800">
            {% for m in members %}
                <li class="px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
                    <div class="flex items-center gap-3 min-w-0">
                        <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-100 dark:bg-brand-500/15 text-brand-700 dark:text-brand-400 text-sm font-semibold shrink-0">
                            {{ (m.user.businessName|default(m.user.email))|slice(0, 2)|upper }}
                        </span>
                        <div class="min-w-0">
                            <p class="text-sm font-medium truncate">{{ m.user.displayName ?: (m.user.businessName ?: m.user.email) }}</p>
                            <p class="text-xs text-slate-500 dark:text-slate-500 truncate">{{ m.user.email }}</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="inline-flex items-center rounded-full {{ m.owner ? 'bg-brand-50 dark:bg-brand-500/10 text-brand-700 dark:text-brand-400' : 'bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300' }} px-2.5 py-0.5 text-xs font-medium">
                            {{ ('team.role.' ~ m.role)|trans }}
                        </span>
                        {% if is_owner and not m.owner %}
                            <form method="POST" action="{{ path('dashboard_team_member_remove', {_locale: locale, userId: m.user.id}) }}"
                                  onsubmit="return confirm('{{ 'team.confirm_remove'|trans|escape('js') }}')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('team-member-remove') }}">
                                <button type="submit" class="text-xs font-medium text-danger-600 hover:text-danger-700 transition">{{ 'team.remove'|trans }}</button>
                            </form>
                        {% elseif not is_owner and m.user.id == user.id %}
                            <form method="POST" action="{{ path('dashboard_team_leave', {_locale: locale}) }}"
                                  onsubmit="return confirm('{{ 'team.confirm_leave'|trans|escape('js') }}')">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('team-leave') }}">
                                <button type="submit" class="text-xs font-medium text-danger-600 hover:text-danger-700 transition">{{ 'team.leave'|trans }}</button>
                            </form>
                        {% endif %}
                    </div>
                </li>
            {% endfor %}
        </ul>
    </section>

    {# ─── Pending invitations ─── #}
    {% if invitations|length > 0 %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden">
            <header class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
                <h2 class="font-semibold tracking-tight">{{ 'team.pending_title'|trans }}</h2>
            </header>
            <ul class="divide-y divide-slate-200 dark:divide-slate-800">
                {% for inv in invitations %}
                    <li class="px-6 py-4 flex items-center justify-between gap-4 flex-wrap">
                        <div class="min-w-0">
                            <p class="text-sm font-medium truncate">{{ inv.email }}</p>
                            <p class="text-xs text-slate-500 dark:text-slate-500">{{ 'team.pending_expires'|trans({'%date%': inv.expiresAt|date('Y-m-d')}) }}</p>
                        </div>
                        {% if is_owner %}
                            <form method="POST" action="{{ path('dashboard_team_invite_revoke', {_locale: locale, id: inv.id}) }}">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('team-invite-revoke') }}">
                                <button type="submit" class="text-xs font-medium text-danger-600 hover:text-danger-700 transition">{{ 'team.revoke_invite'|trans }}</button>
                            </form>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </section>
    {% endif %}
</div>
{% endblock %}
