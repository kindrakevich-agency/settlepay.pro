{% extends 'dashboard/_layout.html.twig' %}

{% set locale = app.request.locale|default('en') %}

{% block dashboard_title %}{{ 'webhooks.title'|trans }}{% endblock %}

{% block dashboard_content %}
<div class="max-w-3xl mx-auto space-y-6">

    <div>
        <a href="{{ path('dashboard_settings', {_locale: locale}) }}"
           class="inline-flex items-center gap-1.5 text-xs font-medium text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-100 transition">
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            {{ 'nav.settings'|trans }}
        </a>
        <h1 class="mt-2 font-display text-2xl sm:text-3xl font-semibold tracking-tight">{{ 'webhooks.title'|trans }}</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{{ 'webhooks.subtitle'|trans }}</p>
    </div>

    {# ─── One-time secret panel ─── #}
    {% if just_created %}
        <div class="rounded-2xl border-2 border-success-500 bg-success-50 dark:bg-success-500/10 p-5">
            <div class="flex items-start gap-3">
                <span class="grid h-6 w-6 place-items-center rounded-full bg-success-500 text-white shrink-0 text-xs font-bold">✓</span>
                <div class="flex-1 min-w-0">
                    <p class="font-semibold text-success-700 dark:text-success-500">{{ 'webhooks.secret_title'|trans }}</p>
                    <p class="mt-1 text-sm text-success-700/80 dark:text-success-500/80">{{ 'webhooks.secret_warning'|trans }}</p>
                    <div class="mt-3 flex items-center gap-2 rounded-xl bg-white dark:bg-slate-950 border border-success-200 dark:border-success-500/30 p-3 font-mono text-xs sm:text-sm break-all">
                        <code class="flex-1" id="secret-plaintext">{{ just_created }}</code>
                        <button type="button"
                                class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-slate-900 dark:bg-white text-white dark:text-slate-900 px-2.5 py-1.5 text-xs font-medium hover:bg-slate-800 dark:hover:bg-slate-100 transition"
                                onclick="navigator.clipboard.writeText(document.getElementById('secret-plaintext').textContent); this.textContent='✓ {{ 'api_tokens.copied'|trans|escape('js') }}'">
                            {{ 'api_tokens.copy'|trans }}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if not user.pro %}
        <div class="rounded-2xl border border-warning-200 dark:border-warning-500/30 bg-warning-50 dark:bg-warning-500/10 p-4">
            <p class="text-sm font-medium text-warning-700 dark:text-warning-500">{{ 'webhooks.free_plan_required'|trans }}</p>
            <a href="{{ path('dashboard_billing', {_locale: locale}) }}"
               class="mt-3 inline-flex items-center gap-1.5 rounded-lg bg-brand-600 hover:bg-brand-700 text-white px-3 py-1.5 text-xs font-medium transition">
                {{ 'billing.upgrade_title'|trans }}
            </a>
        </div>
    {% endif %}

    {% if user.pro %}
        <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-6">
            <h2 class="font-semibold tracking-tight">{{ 'webhooks.add_title'|trans }}</h2>
            <form method="POST" action="{{ path('dashboard_webhooks_create', {_locale: locale}) }}" class="mt-4 space-y-4">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('webhook-create') }}">

                <label class="block">
                    <span class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">{{ 'webhooks.url_label'|trans }}</span>
                    <input type="url" name="url" required
                           placeholder="{{ 'webhooks.url_placeholder'|trans }}"
                           class="block w-full px-3.5 py-2.5 rounded-xl bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-700 placeholder-slate-400 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition text-sm font-mono">
                </label>

                <fieldset>
                    <legend class="text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">{{ 'webhooks.events_label'|trans }}</legend>
                    <div class="grid sm:grid-cols-2 gap-2">
                        {% for ev in all_events %}
                            <label class="flex items-center gap-2.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/60 px-3 py-2 text-sm cursor-pointer hover:border-brand-300 dark:hover:border-brand-700 transition">
                                <input type="checkbox" name="events[]" value="{{ ev }}" checked
                                       class="rounded text-brand-600 focus:ring-brand-500">
                                <span class="font-mono text-xs">{{ ev }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">{{ 'webhooks.events_hint'|trans }}</p>
                </fieldset>

                <div class="flex justify-end pt-2">
                    <button type="submit"
                            class="inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white px-4 py-2.5 text-sm font-medium transition">
                        {{ 'webhooks.create'|trans }}
                    </button>
                </div>
            </form>
        </section>
    {% endif %}

    <section class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 overflow-hidden">
        <header class="px-6 py-4 border-b border-slate-200 dark:border-slate-800">
            <h2 class="font-semibold tracking-tight">{{ 'webhooks.active_title'|trans }}</h2>
        </header>
        {% if webhooks|length == 0 %}
            <div class="p-6 text-center text-sm text-slate-500 dark:text-slate-400">
                {{ 'webhooks.empty'|trans }}
            </div>
        {% else %}
            <ul class="divide-y divide-slate-200 dark:divide-slate-800">
                {% for w in webhooks %}
                    <li class="px-6 py-4 flex items-start justify-between gap-4 flex-wrap">
                        <div class="min-w-0 flex-1">
                            <p class="font-mono text-sm text-slate-900 dark:text-slate-100 break-all">{{ w.url }}</p>
                            <div class="mt-1.5 flex flex-wrap gap-1">
                                {% for ev in w.events %}
                                    <span class="inline-flex items-center rounded-full bg-slate-100 dark:bg-slate-800 px-2 py-0.5 text-2xs font-mono font-medium text-slate-700 dark:text-slate-300">
                                        {{ ev }}
                                    </span>
                                {% endfor %}
                            </div>
                            <p class="mt-1.5 text-xs text-slate-500 dark:text-slate-400">
                                {% if w.lastSuccessAt %}
                                    {{ 'api_tokens.last_used'|trans({'%date%': w.lastSuccessAt|date('Y-m-d H:i')}) }}
                                {% elseif w.lastFailureAt %}
                                    <span class="text-danger-600">{{ w.lastFailureReason ?: 'Last delivery failed' }}</span>
                                {% else %}
                                    {{ 'api_tokens.never_used'|trans }}
                                {% endif %}
                            </p>
                        </div>
                        <form method="POST" action="{{ path('dashboard_webhooks_delete', {_locale: locale, id: w.id}) }}"
                              onsubmit="return confirm('{{ 'webhooks.confirm_delete'|trans|escape('js') }}')">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('webhook-delete') }}">
                            <button type="submit" class="text-xs font-medium text-danger-600 hover:text-danger-700 transition">
                                {{ 'webhooks.delete'|trans }}
                            </button>
                        </form>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </section>

    <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/60 p-5">
        <p class="text-sm font-medium text-slate-900 dark:text-slate-100">{{ 'webhooks.docs_title'|trans }}</p>
        <pre class="mt-3 overflow-x-auto rounded-lg bg-slate-900 dark:bg-black text-slate-100 p-3 text-xs font-mono"><code>POST /your/endpoint  HTTP/1.1
Content-Type: application/json
X-Settlepay-Event: invoice.paid
X-Settlepay-Timestamp: 1746979200
X-Settlepay-Signature: hex(hmac_sha256(timestamp + "." + body, secret))
X-Settlepay-Delivery: 42

{ "event": "invoice.paid", "created_at": "...", "data": { "invoice": { ... } } }</code></pre>
    </div>

</div>
{% endblock %}
