{% extends 'emails/_layout.html.twig' %}

{% block subject %}Reset your settlepay.pro password{% endblock %}

{% block content %}
    <h1 style="margin:0 0 12px;font-size:22px;font-weight:600;letter-spacing:-0.015em;color:#0f172a;">{{ 'emails.reset.heading'|trans }}</h1>
    <p style="margin:0 0 20px;font-size:15px;line-height:1.6;color:#475569;">{{ 'emails.reset.body'|trans }}</p>

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:8px 0 24px;">
        <tr><td style="border-radius:12px;background:#0d9488;">
            <a href="{{ url }}" style="display:inline-block;padding:14px 24px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:12px;">
                {{ 'emails.reset.cta'|trans }}
            </a>
        </td></tr>
    </table>

    <p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#64748b;">{{ 'emails.reset.fallback'|trans }}</p>
    <p style="margin:0;word-break:break-all;font-family:'JetBrains Mono',monospace;font-size:12px;color:#0d9488;">{{ url }}</p>

    <p style="margin:24px 0 0;font-size:13px;line-height:1.6;color:#94a3b8;">{{ 'emails.reset.ignore'|trans }}</p>
{% endblock %}

{% block footer_text %}{{ 'emails.reset.footer'|trans }}{% endblock %}
