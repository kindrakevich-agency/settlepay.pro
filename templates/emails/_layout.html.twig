<!DOCTYPE html>
<html lang="{{ user.defaultLocale|default('en') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block subject %}Settlepay{% endblock %}</title>
</head>
{# Email-friendly inline styles only — no external CSS, no JS. Most clients strip <style>. #}
<body style="margin:0;padding:0;background:#f8fafc;font-family:Inter,Helvetica,Arial,sans-serif;color:#0f172a;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f8fafc;padding:32px 16px;">
        <tr><td align="center">
            <table role="presentation" width="540" cellpadding="0" cellspacing="0" border="0" style="max-width:540px;background:#ffffff;border:1px solid #e2e8f0;border-radius:18px;overflow:hidden;">
                <tr><td style="padding:28px 32px 8px;">
                    {# Brand source: explicit `user` context var, OR invoice.workspace, OR invoice.user, OR none → default. #}
                    {% set _brand_user = user|default(invoice.workspace|default(invoice.user|default(null))) %}
                    {% set _brand_color = _brand_user ? _brand_user.brandColor|default('#0d9488') : '#0d9488' %}
                    {% set _brand_logo  = _brand_user ? _brand_user.brandLogoPath|default(null) : null %}
                    {% if _brand_logo %}
                        <a href="https://settlepay.pro" style="text-decoration:none;display:inline-flex;align-items:center;gap:10px;">
                            <img src="https://settlepay.pro/{{ _brand_logo }}" alt="{{ _brand_user.businessName }}" style="height:32px;border-radius:8px;">
                            {% if _brand_user.businessName %}<span style="font-size:16px;font-weight:600;color:#0f172a;">{{ _brand_user.businessName }}</span>{% endif %}
                        </a>
                    {% else %}
                        <a href="https://settlepay.pro" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
                            <span style="display:inline-block;width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#2dd4bf,{{ _brand_color }});"></span>
                            <span style="font-size:18px;font-weight:600;color:#0f172a;letter-spacing:-0.01em;">
                                <span>settle</span><span style="color:{{ _brand_color }};">pay</span>
                            </span>
                        </a>
                    {% endif %}
                </td></tr>

                <tr><td style="padding:16px 32px 32px;">
                    {% block content %}{% endblock %}
                </td></tr>

                <tr><td style="padding:20px 32px;background:#f8fafc;border-top:1px solid #e2e8f0;font-size:12px;color:#64748b;line-height:1.6;">
                    <p style="margin:0;">{% block footer_text %}You received this because you signed up at settlepay.pro.{% endblock %}</p>
                    <p style="margin:8px 0 0;">© {{ "now"|date("Y") }} settlepay.pro · <a href="https://settlepay.pro" style="color:#0d9488;text-decoration:none;">settlepay.pro</a></p>
                </td></tr>
            </table>
        </td></tr>
    </table>
</body>
</html>
