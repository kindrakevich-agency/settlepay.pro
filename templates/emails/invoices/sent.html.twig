{% extends 'emails/_layout.html.twig' %}

{% block subject %}Invoice {{ invoice.number }} from {{ invoice.user.businessName ?? 'Settlepay' }}{% endblock %}

{% block content %}
    <h1 style="margin:0 0 12px;font-size:22px;font-weight:600;letter-spacing:-0.015em;color:#0f172a;">
        Invoice {{ invoice.number }}
    </h1>
    <p style="margin:0 0 8px;font-size:15px;line-height:1.6;color:#475569;">
        Hi {{ invoice.clientName }} —
    </p>
    <p style="margin:0 0 20px;font-size:15px;line-height:1.6;color:#475569;">
        {{ invoice.user.businessName ?? invoice.user.email|split('@')|first }} sent you an invoice for
        <strong style="color:#0f172a">${{ amount_decimal }}</strong>{% if invoice.dueDate %}, due <strong>{{ invoice.dueDate|format_date('medium') }}</strong>{% endif %}.
        {% if invoice.description %}<br><span style="color:#64748b">{{ invoice.description }}</span>{% endif %}
    </p>

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:8px 0 24px;">
        <tr><td style="border-radius:12px;background:#0d9488;">
            <a href="{{ pay_url }}" style="display:inline-block;padding:14px 28px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:12px;">
                Pay {{ amount_decimal }} {{ invoice.currency }}
            </a>
        </td></tr>
    </table>

    <p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#64748b;">
        Pay with USDC, USDT, or DAI on Base, Polygon, Arbitrum, or Optimism — non-custodial, no account required, settles in seconds.
    </p>

    <p style="margin:16px 0 8px;font-size:13px;line-height:1.6;color:#64748b;">Or paste the link into your browser:</p>
    <p style="margin:0;word-break:break-all;font-family:'JetBrains Mono',monospace;font-size:12px;color:#0d9488;">{{ pay_url }}</p>

    <p style="margin:24px 0 0;font-size:13px;line-height:1.6;color:#94a3b8;">
        Questions about this invoice? Reply directly — your reply goes to {{ invoice.user.email }}.
    </p>
{% endblock %}

{% block footer_text %}You received this because {{ invoice.user.businessName ?? invoice.user.email }} sent you an invoice via settlepay.pro.{% endblock %}
