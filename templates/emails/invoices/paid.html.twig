{% extends 'emails/_layout.html.twig' %}

{% block subject %}Receipt for {{ invoice.number }} from {{ invoice.user.businessName ?? 'Settlepay' }}{% endblock %}

{% block content %}
<h1 style="margin:0 0 12px;font-size:22px;font-weight:600;letter-spacing:-0.015em;color:#0f172a;">Payment received</h1>

<p style="margin:0 0 8px;font-size:15px;line-height:1.6;color:#475569;">Hi {{ invoice.clientName }},</p>

<p style="margin:0 0 20px;font-size:15px;line-height:1.6;color:#475569;">Thanks — your payment of <strong style="color:#0f172a">${{ amount_decimal }} {{ invoice.currency }}</strong> for invoice {{ invoice.number }} has been confirmed on-chain.</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:0 0 24px;border-radius:14px;background:#ecfdf5;border:1px solid #a7f3d0;">
    <tr><td style="padding:18px 20px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
            <tr>
                <td style="font-size:12px;font-weight:600;color:#047857;text-transform:uppercase;letter-spacing:0.5px;padding-bottom:6px;">Paid in full</td>
                <td align="right" style="font-size:12px;color:#047857;font-family:'JetBrains Mono',monospace;">{{ paid_at_text }} UTC</td>
            </tr>
            <tr><td colspan="2" style="font-size:24px;font-weight:600;color:#064e3b;font-variant-numeric:tabular-nums;letter-spacing:-0.5px;">${{ amount_decimal }} {{ invoice.currency }}</td></tr>
        </table>
    </td></tr>
</table>

<p style="margin:0 0 8px;font-size:13px;line-height:1.6;color:#64748b;">The PDF receipt is attached to this email. Save it for your records.</p>

{% if tx_url %}
    <p style="margin:16px 0 8px;font-size:13px;line-height:1.6;color:#64748b;">View the on-chain transaction:</p>
    <p style="margin:0;word-break:break-all;font-family:'JetBrains Mono',monospace;font-size:12px;color:#0d9488;"><a href="{{ tx_url }}" style="color:#0d9488;text-decoration:none;">{{ tx_url }}</a></p>
{% endif %}

<p style="margin:24px 0 0;font-size:13px;line-height:1.6;color:#94a3b8;">Questions about this receipt? Reply directly — your reply goes to {{ invoice.user.email }}.</p>
{% endblock %}

{% block footer_text %}Receipt for an invoice paid via settlepay.pro &mdash; non-custodial stablecoin invoicing.{% endblock %}
