{% extends 'emails/_layout.html.twig' %}

{% block subject %}[Settlepay admin] New signup: {{ user.email }}{% endblock %}

{% block content %}
    <h1 style="margin:0 0 12px;font-size:22px;font-weight:600;letter-spacing:-0.015em;color:#0f172a;">New signup</h1>
    <p style="margin:0 0 16px;font-size:15px;line-height:1.6;color:#475569;">
        A new user just joined Settlepay.
    </p>

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:100%;border-collapse:collapse;margin:8px 0 16px;font-size:14px;">
        <tr><td style="padding:6px 0;color:#64748b;width:120px;">Email</td><td style="padding:6px 0;color:#0f172a;"><strong>{{ user.email }}</strong></td></tr>
        {% if user.displayName %}
        <tr><td style="padding:6px 0;color:#64748b;">Name</td><td style="padding:6px 0;color:#0f172a;">{{ user.displayName }}</td></tr>
        {% endif %}
        <tr><td style="padding:6px 0;color:#64748b;">Method</td><td style="padding:6px 0;color:#0f172a;text-transform:capitalize;">{{ via }}</td></tr>
        <tr><td style="padding:6px 0;color:#64748b;">Locale</td><td style="padding:6px 0;color:#0f172a;">{{ user.defaultLocale|default('en')|upper }}</td></tr>
        <tr><td style="padding:6px 0;color:#64748b;">When</td><td style="padding:6px 0;color:#0f172a;">{{ signed_up_at|date('Y-m-d H:i:s T') }}</td></tr>
        <tr><td style="padding:6px 0;color:#64748b;">User ID</td><td style="padding:6px 0;color:#0f172a;font-family:'JetBrains Mono',monospace;font-size:12px;">{{ user.id }}</td></tr>
    </table>

    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:16px 0 8px;">
        <tr><td style="border-radius:12px;background:#0d9488;">
            <a href="https://settlepay.pro/en/app/admin/users" style="display:inline-block;padding:11px 20px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:12px;">
                Open admin → Users
            </a>
        </td></tr>
    </table>
{% endblock %}

{% block footer_text %}You receive this because you are in ADMIN_EMAILS on the Settlepay server.{% endblock %}
