# Settle — committed defaults. Override anything sensitive in .env.local.
# https://symfony.com/doc/current/configuration.html#configuration-environments

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=changeme_in_dotenv_local
APP_URL=http://localhost:8080
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1|settlepay\.pro|www\.settlepay\.pro)$'
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: mysql://USER:PASSWORD@HOST:PORT/DB?serverVersion=10.11.6-MariaDB&charset=utf8mb4
DATABASE_URL="mysql://settle:settle@db:3306/settle?serverVersion=10.11.6-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> symfony/lock ###
# RateLimiter needs a lock store. flock = local filesystem locks (single-node).
# For multi-node deploys swap to redis://...
LOCK_DSN=flock
###< symfony/lock ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

###> symfony/mailer ###
# In production set Resend or Postmark DSN in .env.local
MAILER_DSN=null://null

# What every outgoing email is From: — change in one place. AuthMailer +
# SendTestEmailCommand read these via DI, never hardcode. We deliberately
# don't use noreply@ — Gmail/Outlook give it lower trust scores and it
# discourages legitimate replies. See README §14.
MAILER_FROM_ADDRESS=hello@settlepay.pro
MAILER_FROM_NAME=Settlepay
###< symfony/mailer ###

###> blockchain RPC URLs ###
# Public fallbacks — replace with Alchemy/QuickNode URLs (incl. API key) in .env.local for higher rate limits.
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
OP_SEPOLIA_RPC_URL=https://sepolia.optimism.io
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
###< blockchain RPC URLs ###

###> external services ###
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
SENTRY_DSN=
###< external services ###
