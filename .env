# Settle — committed defaults. Override anything sensitive in .env.local.
# https://symfony.com/doc/current/configuration.html#configuration-environments

###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=changeme_in_dotenv_local
APP_URL=http://localhost:8080
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1|settlepay\.pro|www\.settlepay\.pro)$'
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format: mysql://USER:PASSWORD@HOST:PORT/DB?serverVersion=10.11.6-MariaDB&charset=utf8mb4
DATABASE_URL="mysql://settle:settle@db:3306/settle?serverVersion=10.11.6-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL=redis://redis:6379
###< redis ###

###> symfony/lock ###
# RateLimiter needs a lock store. flock = local filesystem locks (single-node).
# For multi-node deploys swap to redis://...
LOCK_DSN=flock
###< symfony/lock ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=1
###< symfony/messenger ###

###> symfony/mailer ###
# In production set Resend or Postmark DSN in .env.local
MAILER_DSN=null://null

# What every outgoing email is From: — change in one place. AuthMailer +
# SendTestEmailCommand read these via DI, never hardcode. We deliberately
# don't use noreply@ — Gmail/Outlook give it lower trust scores and it
# discourages legitimate replies. See README §14.
MAILER_FROM_ADDRESS=hello@settlepay.pro
MAILER_FROM_NAME=Settlepay
###< symfony/mailer ###

###> blockchain RPC URLs ###
# Defaults are publicnode + drpc — both have aggregator-style routing and
# stayed up while the "official" sequencer URLs (mainnet.base.org,
# polygon-rpc.com etc.) intermittently 503'd in May 2026. Replace with
# Alchemy / QuickNode / Infura URLs in .env.local for higher rate limits.
BASE_RPC_URL=https://base.publicnode.com
POLYGON_RPC_URL=https://polygon-bor.publicnode.com
ARBITRUM_RPC_URL=https://arbitrum-one.publicnode.com
OPTIMISM_RPC_URL=https://optimism.publicnode.com
BASE_SEPOLIA_RPC_URL=https://base-sepolia.drpc.org
OP_SEPOLIA_RPC_URL=https://optimism-sepolia.drpc.org
ARB_SEPOLIA_RPC_URL=https://arbitrum-sepolia.drpc.org

# Max blocks per eth_getLogs call. Alchemy free tier rejects > 10;
# Alchemy PAYG / publicnode / drpc allow thousands. Bump to 500+ in
# .env.local if you have a paid plan or a permissive RPC.
LISTENER_MAX_BATCH_BLOCKS=9
###< blockchain RPC URLs ###

###> external services ###
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
SENTRY_DSN=
###< external services ###

###> google sign-in (GIS / ID token flow) ###
# Set both to enable. Hide the Google buttons + return 404 from
# /auth/google by setting GOOGLE_AUTH_ENABLED=0 (useful for emergencies).
# CLIENT_ID is the OAuth 2.0 Web client from console.cloud.google.com.
# Public-by-design — it ships in the JS bundle, but only valid against
# the Authorized JavaScript origins allowlist on the issuer side.
GOOGLE_AUTH_ENABLED=0
GOOGLE_CLIENT_ID=
###< google sign-in ###

###> billing — crypto-native (no Stripe) ###
# The wallet that receives Pro subscription + per-invoice fee payments.
# Same EVM address works across Base / Polygon / Arbitrum / Optimism.
# Empty here on purpose — set the real wallet in .env.local on the server.
# When unset, the dashboard /app/billing page shows a "platform wallet
# not configured" warning and intent creation throws — preventing
# orphan payments to a placeholder address.
PLATFORM_WALLET_ADDRESS=

# Dev / founder dogfood: accept Sepolia testnet chains for billing intents
# so you can complete the Pro-upgrade flow with free faucet USDC. Stays
# false in production — leaving this on would let anyone get a $19 Pro
# subscription by paying $19 of worthless faucet USDC.
BILLING_ALLOW_TESTNETS=
###< billing ###
